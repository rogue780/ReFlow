module jsonq.jsonq

; jsonq — command-line JSON query tool
;
; Usage: jsonq <file> <query> [query...] [--pretty]
;   file   — path to a JSON file, or "-" to read from stdin
;   query  — dot-path expression (e.g. "users.0.name", "items.*.id")
;
; Query syntax:
;   "name"           — object key access
;   "users.0"        — array index access
;   "users.#"        — array/object/string length
;   "users.*.name"   — wildcard: iterate all array elements
;   "name?type"      — type introspection (returns "string", "number", etc.)
;
; Responses:
;   Strings print without quotes (pipe-friendly).
;   Objects/arrays print as JSON (compact, or indented with --pretty).
;   Errors go to stderr with exit code 1.

import io
import sys
import string
import array
import json
import conv

; ===========================================================================
; JSON type tag constants (match FL_JSON_* defines in runtime)
; ===========================================================================

; Tags returned by json.type_tag():
;   0=null, 1=bool, 2=int, 3=float, 4=string, 5=array, 6=object

; ===========================================================================
; Path parsing
; ===========================================================================

; Split a dot-path into segments. Returns (segments, error_message).
; An empty query returns an empty array (meaning "root").
fn:pure parse_path(query: string): (array<string>, string) {
    if string.len(query) == 0 {
        return ([], "")
    }

    ; Check for leading/trailing dots
    if string.starts_with(query, ".") {
        return ([], "leading dot in path")
    }
    if string.ends_with(query, ".") {
        return ([], "trailing dot in path")
    }

    ; Check for ?type suffix — split it off as a segment
    let q: string:mut = query
    let has_type_suffix: bool:mut = false
    if string.ends_with(q, "?type") {
        let prefix_len = string.len(q) - 5
        q = if prefix_len > 0 { string.substring(q, 0, prefix_len) } else { "" }
        has_type_suffix = true
    }

    let segments: array<string>:mut = []

    if string.len(q) > 0 {
        let parts = string.split(q, ".")
        let i: int:mut = 0
        while (i < array.len_string(parts)) {
            if let some(part) = array.get(parts, i) {
                if string.len(part) == 0 {
                    return ([], "empty segment (double dot)")
                }
                segments = array.push(segments, part)
            }
            i = i + 1
        }
    }

    if has_type_suffix {
        segments = array.push(segments, "?type")
    }

    return (segments, "")
}

; Check if a segment string is a non-negative integer (array index).
fn:pure is_array_index(segment: string): bool {
    if string.len(segment) == 0 { return false }
    match conv.string_to_int64(segment) {
        some(n): { return n >= 0 }
        none: { return false }
    }
}

; ===========================================================================
; Type name helper
; ===========================================================================

fn:pure type_name(val: JsonValue): string {
    let tag = json.type_tag(val)
    if tag == 0 { return "null" }
    if tag == 1 { return "boolean" }
    if tag == 2 { return "number" }
    if tag == 3 { return "number" }
    if tag == 4 { return "string" }
    if tag == 5 { return "array" }
    if tag == 6 { return "object" }
    return "unknown"
}

; ===========================================================================
; Length helper — works on arrays, objects, and strings
; ===========================================================================

fn:pure value_length(val: JsonValue): JsonValue? {
    let tag = json.type_tag(val)

    ; Array length
    if tag == 5 {
        match json.as_array(val) {
            some(arr): { return some(json.int_val(array.size(arr))) }
            none: { return some(json.int_val(0)) }
        }
    }

    ; Object key count
    if tag == 6 {
        match json.keys(val) {
            some(keys): { return some(json.int_val(array.len_string(keys))) }
            none: { return some(json.int_val(0)) }
        }
    }

    ; String character count
    if tag == 4 {
        match json.as_string(val) {
            some(s): { return some(json.int_val(string.len(s))) }
            none: { return some(json.int_val(0)) }
        }
    }

    return none
}

; ===========================================================================
; Path resolution — the core query engine
; ===========================================================================

; Resolve a single segment against a single JSON value.
; Returns an array because wildcard (*) can produce multiple results.
fn resolve_segment(val: JsonValue, segment: string): array<JsonValue> {
    ; Length operator
    if segment == "#" {
        match value_length(val) {
            some(v): { return [v] }
            none: { return [] }
        }
    }

    ; Type introspection
    if segment == "?type" {
        return [json.string_val(type_name(val))]
    }

    ; Wildcard — iterate all array elements
    if segment == "*" {
        match json.as_array(val) {
            some(arr): { return arr }
            none: { return [] }
        }
    }

    ; Array index
    if is_array_index(segment) {
        if let some(idx) = conv.string_to_int64(segment) {
            match json.get_index(val, idx) {
                some(v): { return [v] }
                none: { return [] }
            }
        }
        return []
    }

    ; Object key access
    match json.get(val, segment) {
        some(v): { return [v] }
        none: { return [] }
    }
}

; Resolve a full path (array of segments) against a JSON value.
; Returns all matching values (multiple when wildcards are used).
fn resolve(root: JsonValue, segments: array<string>): array<JsonValue> {
    let current: array<JsonValue>:mut = [root]
    let i: int:mut = 0

    while (i < array.len_string(segments)) {
        if let some(segment) = array.get(segments, i) {
            let next: array<JsonValue>:mut = []
            let j: int:mut = 0
            while (j < array.size(current)) {
                if let some(val) = array.get_any(current, j) {
                    let results = resolve_segment(val, segment)
                    next = array.concat(next, results)
                }
                j = j + 1
            }
            current = next
        }
        i = i + 1
    }

    return current
}

; ===========================================================================
; Output formatting
; ===========================================================================

; Format a single JSON value for output.
; Strings are printed raw (no quotes) for pipe-friendliness.
fn:pure format_value(val: JsonValue, pretty: bool): string {
    let tag = json.type_tag(val)

    ; Strings — raw output
    if tag == 4 {
        return json.as_string(val) ?? ""
    }

    ; Objects and arrays — JSON format
    if tag == 5 || tag == 6 {
        if pretty {
            return json.to_string_pretty(val, 2)
        }
        return json.to_string(val)
    }

    ; Everything else (int, float, bool, null) — JSON literal
    return json.to_string(val)
}

; Print all resolved values, one per line.
fn print_results(results: array<JsonValue>, pretty: bool): none {
    let i: int:mut = 0
    while (i < array.size(results)) {
        if let some(val) = array.get_any(results, i) {
            io.println(format_value(val, pretty))
        }
        i = i + 1
    }
}

; ===========================================================================
; CLI helpers
; ===========================================================================

; Check if an argument is a flag (starts with "--").
fn:pure is_flag(arg: string): bool {
    return string.starts_with(arg, "--")
}

; Read file contents, or stdin if path is "-".
fn read_input(file_path: string): string? {
    if file_path == "-" {
        return io.read_stdin()
    }
    return io.read_file(file_path)
}

; ===========================================================================
; Main
; ===========================================================================

fn main(): none {
    let argv = sys.args()
    let argc = array.len_string(argv)

    if argc < 2 {
        io.eprintln("Usage: jsonq <file> <query> [query...] [--pretty]")
        io.eprintln("")
        io.eprintln("  file   — JSON file path, or \"-\" for stdin")
        io.eprintln("  query  — dot-path expression (e.g. \"name\", \"users.0.email\")")
        io.eprintln("")
        io.eprintln("Query syntax:")
        io.eprintln("  key        object field access")
        io.eprintln("  0          array index access")
        io.eprintln("  #          length (array, object, or string)")
        io.eprintln("  *          wildcard (iterate array elements)")
        io.eprintln("  ?type      type introspection suffix")
        io.eprintln("  --pretty   indented output for objects/arrays")
        sys.exit(1)
    }

    ; Parse args: first non-flag is the file, rest are queries or flags
    let file_path = array.get(argv, 1) ?? ""

    let pretty: bool:mut = false
    let queries: array<string>:mut = []
    let i: int:mut = 2
    while (i < argc) {
        if let some(arg) = array.get(argv, i) {
            if arg == "--pretty" {
                pretty = true
            } else {
                if !is_flag(arg) {
                    queries = array.push(queries, arg)
                }
            }
        }
        i = i + 1
    }

    ; If no queries given, default to root (empty query = print whole doc)
    if array.len_string(queries) == 0 {
        queries = array.push(queries, "")
    }

    ; Read and parse JSON
    let content = read_input(file_path)
    match content {
        none: {
            io.eprintln("Error: file '" + file_path + "' not found")
            sys.exit(1)
        }
        some(data): {
            match json.parse(data) {
                none: {
                    io.eprintln("Error: invalid JSON")
                    sys.exit(1)
                }
                some(root): {
                    run_queries(root, queries, pretty)
                }
            }
        }
    }
}

; Run all queries against the parsed JSON root.
fn run_queries(root: JsonValue, queries: array<string>, pretty: bool): none {
    let i: int:mut = 0
    while (i < array.len_string(queries)) {
        if let some(query) = array.get(queries, i) {
            run_single_query(root, query, pretty)
        }
        i = i + 1
    }
}

; Run a single query: parse the path, resolve, print results.
fn run_single_query(root: JsonValue, query: string, pretty: bool): none {
    let parsed = parse_path(query)
    let segments = parsed.0
    let parse_err = parsed.1

    if string.len(parse_err) > 0 {
        io.eprintln("Error: invalid query path '" + query + "': " + parse_err)
        sys.exit(1)
    }

    let results = resolve(root, segments)

    if array.size(results) == 0 {
        io.eprintln("Error: path '" + query + "' not found")
        sys.exit(1)
    }

    print_results(results, pretty)
}
