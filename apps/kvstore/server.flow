module kvstore.server

; server.flow — In-memory key-value store with TCP text protocol
;
; Usage: server [port]
;   port — TCP port to listen on (default: 6379)
;
; Connect with: nc localhost <port>
;
; Protocol:
;   SET key value     → +OK
;   GET key           → +value   or  -ERR key not found
;   DEL key           → +1       or  +0
;   KEYS              → +key1 key2 key3 ...
;   COUNT             → +N
;   EXISTS key        → +1       or  +0
;   FLUSHALL          → +OK
;   SAVE              → +OK      (snapshot to disk)
;   LOAD              → +OK (N keys loaded)
;   PING              → +PONG
;   QUIT              → (closes connection)
;
; Architecture:
;   - Main thread runs a non-blocking event loop
;   - Listener socket has a short timeout for non-blocking accept
;   - Each client gets a receivable coroutine (inbox: stream<string>)
;   - Client coroutines yield "addr|line" messages to the main thread
;   - Main thread polls each client with .poll() (non-blocking)
;   - Dispatch is single-writer: store is owned by main(), all mutations here
;   - Responses sent via net.write_to_fd

import net
import io
import sys
import conv
import string
import map
import array
import time
import json
import path

; ===========================================================================
; Pure helpers
; ===========================================================================

; Format a timestamp prefix for server console logging.
fn timestamp(): string {
    let dt = time.datetime_now()
    let h = conv.to_string(time.hour(dt))
    let m = conv.to_string(time.minute(dt))
    let s = conv.to_string(time.second(dt))
    let hh = if string.len(h) < 2 { "0" + h } else { h }
    let mm = if string.len(m) < 2 { "0" + m } else { m }
    let ss = if string.len(s) < 2 { "0" + s } else { s }
    return "[" + hh + ":" + mm + ":" + ss + "]"
}

fn log(msg: string): none {
    io.println(timestamp() + " " + msg)
}

; Parse a command line into (COMMAND, [arg1, arg2, ...]).
; Command is uppercased. Leading/trailing whitespace is trimmed.
fn:pure parse_command(line: string): (string, array<string>) {
    let trimmed = string.trim(line)
    if string.len(trimmed) == 0 {
        return ("", [])
    }
    let parts = string.split(trimmed, " ")
    ; First token is the command, uppercased
    if let some(cmd_raw) = array.get(parts, 0) {
        let cmd = string.to_upper(cmd_raw)
        ; Remaining tokens are args
        let args: array<string>:mut = []
        let i: int:mut = 1
        while (i < array.len_string(parts)) {
            if let some(part) = array.get(parts, i) {
                ; Skip empty parts from multiple spaces
                if string.len(part) > 0 {
                    args = array.push(args, part)
                }
            }
            i = i + 1
        }
        return (cmd, args)
    }
    return ("", [])
}

; Format a success response.
fn:pure ok_response(msg: string): string {
    return "+" + msg + "\r\n"
}

; Format an error response.
fn:pure err_response(msg: string): string {
    return "-ERR " + msg + "\r\n"
}

; ===========================================================================
; Persistence — serialize / deserialize
; ===========================================================================

; Serialize the store to a JSON string.
fn serialize_store(store: map<string, string>): string {
    let keys = map.keys(store)
    let json_map: map<string, JsonValue>:mut = map.new()
    let i: int:mut = 0
    while (i < array.len_string(keys)) {
        if let some(k) = array.get(keys, i) {
            if let some(v) = map.get(store, k) {
                json_map = map.set(json_map, k, json.string_val(v))
            }
        }
        i = i + 1
    }
    let obj = json.object_val(json_map)
    return json.to_string_pretty(obj, 2)
}

; Deserialize a JSON string back to a store map.
fn deserialize_store(data: string): map<string, string>? {
    if let some(obj) = json.parse(data) {
        if let some(keys) = json.keys(obj) {
            let store: map<string, string>:mut = map.new()
            let i: int:mut = 0
            while (i < array.len_string(keys)) {
                if let some(k) = array.get(keys, i) {
                    if let some(jval) = json.get(obj, k) {
                        if let some(s) = json.as_string(jval) {
                            store = map.set(store, k, s)
                        }
                    }
                }
                i = i + 1
            }
            return some(store)
        }
    }
    return none
}

; ===========================================================================
; Command dispatch — processes a parsed command against the store
; ===========================================================================

; Returns (updated_store, response_string).
fn dispatch_command(
    cmd: string,
    args: array<string>,
    store: map<string, string>
): (map<string, string>, string) {
    match cmd {
        "PING": {
            return (store, ok_response("PONG"))
        }
        "SET": {
            if array.len_string(args) < 2 {
                return (store, err_response("SET requires key and value"))
            }
            let key = array.get(args, 0) ?? ""
            ; Value is everything after the key — rejoin args[1..] to support
            ; values with spaces.
            let val_parts: array<string>:mut = []
            let i: int:mut = 1
            while (i < array.len_string(args)) {
                if let some(p) = array.get(args, i) {
                    val_parts = array.push(val_parts, p)
                }
                i = i + 1
            }
            let value = string.join(val_parts, " ")
            let new_store = map.set(store, key, value)
            return (new_store, ok_response("OK"))
        }
        "GET": {
            if array.len_string(args) < 1 {
                return (store, err_response("GET requires a key"))
            }
            let key = array.get(args, 0) ?? ""
            match map.get(store, key) {
                some(val): {
                    return (store, ok_response(val))
                }
                none: {
                    return (store, err_response("key not found"))
                }
            }
        }
        "DEL": {
            if array.len_string(args) < 1 {
                return (store, err_response("DEL requires a key"))
            }
            let key = array.get(args, 0) ?? ""
            if map.has(store, key) {
                let new_store = map.remove(store, key)
                return (new_store, ok_response("1"))
            } else {
                return (store, ok_response("0"))
            }
        }
        "KEYS": {
            let keys = map.keys(store)
            let result = string.join(keys, " ")
            return (store, ok_response(result))
        }
        "COUNT": {
            let n = map.len(store)
            return (store, ok_response(conv.to_string(n)))
        }
        "EXISTS": {
            if array.len_string(args) < 1 {
                return (store, err_response("EXISTS requires a key"))
            }
            let key = array.get(args, 0) ?? ""
            if map.has(store, key) {
                return (store, ok_response("1"))
            } else {
                return (store, ok_response("0"))
            }
        }
        "FLUSHALL": {
            let new_store: map<string, string> = map.new()
            return (new_store, ok_response("OK"))
        }
        "SAVE": {
            let json_str = serialize_store(store)
            let wrote = io.write_file("kvstore.dat", json_str)
            if wrote {
                return (store, ok_response("OK"))
            } else {
                return (store, err_response("write failed"))
            }
        }
        "LOAD": {
            if let some(data) = io.read_file("kvstore.dat") {
                if let some(loaded) = deserialize_store(data) {
                    let n = map.len(loaded)
                    return (loaded, ok_response("OK (" + conv.to_string(n) + " keys loaded)"))
                } else {
                    return (store, err_response("corrupt data file"))
                }
            } else {
                return (store, err_response("file not found"))
            }
        }
        _: {
            return (store, err_response("unknown command '" + cmd + "'"))
        }
    }
}

; ===========================================================================
; Client coroutine — runs on its own thread
; ===========================================================================

; A receivable coroutine that reads lines from the client socket.
; Yields "addr|line" strings for the main thread to parse and dispatch.
fn client_handler(inbox: stream<string>, client: Socket, addr: string): stream<string> {
    net.set_timeout(client, 100)
    let alive: bool:mut = true

    while (alive) {
        ; Drain inbox (not used for responses — responses go via fd)
        for (msg: string in inbox) {}

        ; Try to read from the socket
        match net.read(client, 4096) {
            some(data): {
                let raw = string.trim(string.from_bytes(data))
                if string.len(raw) > 0 {
                    yield addr + "|" + raw
                }
            }
            none: {
                ; Timeout or connection close — keep looping.
                ; A real disconnect will be caught when write fails.
            }
        }
    }
}

; ===========================================================================
; Main thread — non-blocking event loop
; ===========================================================================

fn main(): none {
    let argv = sys.args()
    let port: int:mut = 6379

    if let some(port_str) = array.get(argv, 1) {
        if let some(p) = conv.string_to_int(port_str) {
            port = p
        } else {
            io.eprintln("Invalid port: " + port_str)
            sys.exit(1)
        }
    }

    io.println("Flow KV Store v1.0")

    ; Auto-load persisted data on startup
    let store: map<string, string>:mut = map.new()
    if path.exists("kvstore.dat") {
        if let some(data) = io.read_file("kvstore.dat") {
            if let some(loaded) = deserialize_store(data) {
                store = loaded
                log("Loaded " + conv.to_string(map.len(store)) + " keys from kvstore.dat")
            }
        }
    }

    if let some(listener) = net.listen("0.0.0.0", port) {
        io.println("Listening on port " + conv.to_string(port))
        io.println("Connect with: nc localhost " + conv.to_string(port))

        ; Set short timeout on listener for non-blocking accept
        net.set_timeout(listener, 50)

        ; Client state
        let client_fds: map<string, string>:mut = map.new()
        let handlers: array<Coroutine<string>>:mut = []
        let handler_addrs: array<string>:mut = []

        ; Main event loop
        while (true) {
            ; 1. Non-blocking accept
            if let some(client) = net.accept(listener) {
                let addr = net.remote_addr(client) ?? "unknown"
                let fd = net.fd(client)
                client_fds = map.set(client_fds, addr, conv.to_string(fd))

                log("[connect] " + addr)

                ; Spawn client coroutine
                let handler :< client_handler(client, addr)
                handlers = array.push(handlers, handler)
                handler_addrs = array.push(handler_addrs, addr)
            }

            ; 2. Poll each client handler (non-blocking)
            let i: int:mut = 0
            while (i < array.size(handlers)) {
                if let some(handler) = array.get_any(handlers, i) {
                    if let some(raw_msg) = handler.poll() {
                        ; Parse "addr|message" format
                        if let some(pipe_idx) = string.index_of(raw_msg, "|") {
                            let sender_addr = string.substring(raw_msg, 0, pipe_idx)
                            let line = string.substring(raw_msg, pipe_idx + 1, string.len(raw_msg))

                            let parsed = parse_command(line)
                            let cmd = parsed.0
                            let args = parsed.1

                            ; Handle QUIT specially
                            if cmd == "QUIT" {
                                ; Send goodbye and clean up
                                if let some(fs) = map.get(client_fds, sender_addr) {
                                    if let some(f) = conv.string_to_int(fs) {
                                        net.write_to_fd(f, ok_response("Goodbye"))
                                    }
                                }
                                client_fds = map.remove(client_fds, sender_addr)
                                log("[disconnect] " + sender_addr + " (QUIT)")
                            } else {
                                if string.len(cmd) > 0 {
                                    let result = dispatch_command(cmd, args, store)
                                    store = result.0
                                    let response = result.1

                                    ; Send response via fd
                                    if let some(fs) = map.get(client_fds, sender_addr) {
                                        if let some(f) = conv.string_to_int(fs) {
                                            let sent = net.write_to_fd(f, response)
                                            if !sent {
                                                ; Dead client
                                                client_fds = map.remove(client_fds, sender_addr)
                                                log("[disconnect] " + sender_addr + " (write failed)")
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    } else {
                        ; Nothing ready — check if coroutine is done
                        if handler.done() {
                            if let some(addr) = array.get_any(handler_addrs, i) {
                                client_fds = map.remove(client_fds, addr)
                                log("[disconnect] " + addr + " (connection closed)")
                            }
                        }
                    }
                }
                i = i + 1
            }

            ; 3. Small sleep to prevent busy-wait
            time.sleep_ms(10)
        }

        net.close(listener)
    } else {
        io.eprintln("Failed to listen on 0.0.0.0:" + conv.to_string(port))
        io.eprintln("Is the port already in use?")
        sys.exit(1)
    }
}
