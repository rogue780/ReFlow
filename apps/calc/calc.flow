module calc

// calc.flow — Interactive expression calculator
//
// Usage: python main.py run apps/calc/calc.flow
//
// Features:
//   - Arithmetic: + - * / % ^
//   - Parentheses for grouping
//   - Unary negation: -5, -(2+3)
//   - Variable assignment: let x = 10
//   - Variable reference in expressions: x * 2 + 1
//   - Commands: vars, clear, help, quit/exit
//
// Language features exercised:
//   Recursive sum type (Expr), recursive match, fn:pure, tuples,
//   option<T>, map<string, float>, while loops with :mut

import io
import string
import conv
import math
import map
import array
import char

// ===========================================================================
// AST — recursive expression tree
// ===========================================================================

type Expr =
    | Literal(value: float)
    | Var(name: string)
    | Neg(inner: Expr)
    | BinOp(op: string, left: Expr, right: Expr)

// ===========================================================================
// Parser — single-pass recursive descent over the input string
//
// Each parse function takes (input, pos) and returns (Expr, new_pos).
// Whitespace is skipped at the start of each parse function.
// ===========================================================================

// Skip whitespace starting at pos
fn:pure skip_ws(input: string, pos: int): int {
    let p: int:mut = pos
    let length = string.len(input)
    while (p < length) {
        let ch = string.char_at(input, p) ?? 'x'
        if (char.is_whitespace(ch)) {
            p = p + 1
        } else {
            break
        }
    }
    return p
}

// Peek at the character at pos (after skipping whitespace)
fn:pure peek_char(input: string, pos: int): string {
    let p = skip_ws(input, pos)
    if (p >= string.len(input)) {
        return ""
    }
    let ch = string.char_at(input, p) ?? ' '
    return char.to_string(ch)
}

// Parse a number: digits with optional decimal point
fn parse_number(input: string, pos: int): (Expr, int) {
    let start = pos
    let p: int:mut = pos
    let length = string.len(input)

    // Integer part
    while (p < length) {
        let ch = string.char_at(input, p) ?? ' '
        if (char.is_digit(ch)) {
            p = p + 1
        } else {
            break
        }
    }

    // Decimal part
    if (p < length) {
        let dot = string.char_at(input, p) ?? ' '
        if (char.to_string(dot) == ".") {
            p = p + 1
            while (p < length) {
                let ch = string.char_at(input, p) ?? ' '
                if (char.is_digit(ch)) {
                    p = p + 1
                } else {
                    break
                }
            }
        }
    }

    let num_str = string.substring(input, start, p)
    let value = conv.string_to_float(num_str) ?? 0.0
    return (Literal(value), p)
}

// Parse an identifier: [a-zA-Z_][a-zA-Z0-9_]*
fn parse_ident(input: string, pos: int): (string, int) {
    let start = pos
    let p: int:mut = pos
    let length = string.len(input)

    while (p < length) {
        let ch = string.char_at(input, p) ?? ' '
        if (char.is_alphanumeric(ch)) {
            p = p + 1
        } else {
            let cs = char.to_string(ch)
            if (cs == "_") {
                p = p + 1
            } else {
                break
            }
        }
    }

    return (string.substring(input, start, p), p)
}

// parse_primary: numbers, identifiers, parenthesized expressions
fn parse_primary(input: string, pos: int): (Expr, int) {
    let p = skip_ws(input, pos)

    if (p >= string.len(input)) {
        io.eprintln("Error: unexpected end of expression")
        return (Literal(0.0), p)
    }

    let ch = string.char_at(input, p) ?? ' '

    // Number
    if (char.is_digit(ch)) {
        return parse_number(input, p)
    }

    // Identifier
    if (char.is_alpha(ch)) {
        let result = parse_ident(input, p)
        let name = result.0
        return (Var(name), result.1)
    }

    // Parenthesized expression
    let cs = char.to_string(ch)
    if (cs == "(") {
        let inner = parse_expr(input, p + 1)
        let close_pos = skip_ws(input, inner.1)
        if (close_pos < string.len(input)) {
            let close_ch = string.char_at(input, close_pos) ?? ' '
            if (char.to_string(close_ch) == ")") {
                return (inner.0, close_pos + 1)
            }
        }
        io.eprintln("Error: expected ')'")
        return (inner.0, inner.1)
    }

    io.eprintln("Error: unexpected character '" + cs + "'")
    return (Literal(0.0), p + 1)
}

// parse_unary: handle prefix minus
fn parse_unary(input: string, pos: int): (Expr, int) {
    let p = skip_ws(input, pos)
    if (p < string.len(input)) {
        let ch = string.char_at(input, p) ?? ' '
        if (char.to_string(ch) == "-") {
            let result = parse_unary(input, p + 1)
            return (Neg(result.0), result.1)
        }
    }
    return parse_primary(input, p)
}

// parse_power: right-associative exponentiation (^)
fn parse_power(input: string, pos: int): (Expr, int) {
    let base = parse_unary(input, pos)
    let p = skip_ws(input, base.1)
    if (p < string.len(input)) {
        let ch = string.char_at(input, p) ?? ' '
        if (char.to_string(ch) == "^") {
            // Right-associative: recurse
            let exp = parse_power(input, p + 1)
            return (BinOp("^", base.0, exp.0), exp.1)
        }
    }
    return (base.0, base.1)
}

// parse_multiplicative: * / % (left-associative)
fn parse_multiplicative(input: string, pos: int): (Expr, int) {
    let first = parse_power(input, pos)
    let left: Expr:mut = first.0
    let cur: int:mut = first.1
    let running: bool:mut = true

    while (running) {
        let p = skip_ws(input, cur)
        if (p >= string.len(input)) {
            running = false
        } else {
            let ch = peek_char(input, cur)
            if (ch == "*") {
                let rhs = parse_power(input, p + 1)
                left = BinOp("*", left, rhs.0)
                cur = rhs.1
            } else if (ch == "/") {
                let rhs = parse_power(input, p + 1)
                left = BinOp("/", left, rhs.0)
                cur = rhs.1
            } else if (ch == "%") {
                let rhs = parse_power(input, p + 1)
                left = BinOp("%", left, rhs.0)
                cur = rhs.1
            } else {
                running = false
            }
        }
    }

    return (left, cur)
}

// parse_additive: + - (left-associative)
fn parse_additive(input: string, pos: int): (Expr, int) {
    let first = parse_multiplicative(input, pos)
    let left: Expr:mut = first.0
    let cur: int:mut = first.1
    let running: bool:mut = true

    while (running) {
        let p = skip_ws(input, cur)
        if (p >= string.len(input)) {
            running = false
        } else {
            let ch = peek_char(input, cur)
            if (ch == "+") {
                let rhs = parse_multiplicative(input, p + 1)
                left = BinOp("+", left, rhs.0)
                cur = rhs.1
            } else if (ch == "-") {
                let rhs = parse_multiplicative(input, p + 1)
                left = BinOp("-", left, rhs.0)
                cur = rhs.1
            } else {
                running = false
            }
        }
    }

    return (left, cur)
}

// parse_expr: top-level entry point
fn parse_expr(input: string, pos: int): (Expr, int) {
    return parse_additive(input, pos)
}

// ===========================================================================
// Evaluator — recursive match over the Expr tree
// ===========================================================================

fn eval_binop(op: string, lv: float, rv: float): float {
    if (op == "+") { return lv + rv }
    if (op == "-") { return lv - rv }
    if (op == "*") { return lv * rv }
    if (op == "^") { return math.pow(lv, rv) }
    if (op == "/") {
        if (rv == 0.0) {
            io.eprintln("Error: division by zero")
            return 0.0
        }
        return lv / rv
    }
    if (op == "%") {
        if (rv == 0.0) {
            io.eprintln("Error: modulo by zero")
            return 0.0
        }
        return lv % rv
    }
    return 0.0
}

fn eval(expr: Expr, env: map<string, float>): float {
    match expr {
        Literal(n): n
        Var(name): map.get(env, name) ?? 0.0
        Neg(inner): 0.0 - eval(inner, env)
        BinOp(op, left, right): eval_binop(op, eval(left, env), eval(right, env))
    }
}

// ===========================================================================
// Display and helpers
// ===========================================================================

fn format_result(value: float): string {
    let as_int = cast<int>(value)
    if (cast<float>(as_int) == value) {
        return conv.to_string(as_int)
    }
    return conv.to_string(value)
}

fn eval_input(input: string, env: map<string, float>): string {
    let parsed = parse_expr(input, 0)
    return format_result(eval(parsed.0, env))
}

// ===========================================================================
// REPL — read-eval-print loop
// ===========================================================================

fn print_help(): none {
    io.println("Flow Calculator")
    io.println("  Operators: + - * / % ^ ()")
    io.println("  Variables: let x = 10")
    io.println("  Commands:  vars, clear, help, quit")
}

fn print_vars(env: map<string, float>): none {
    let keys = map.keys(env)
    if (array.len_string(keys) == 0) {
        io.println("(no variables)")
        return
    }
    let i: int:mut = 0
    while (i < array.len_string(keys)) {
        if (let some(k) = array.get(keys, i)) {
            let v = map.get(env, k) ?? 0.0
            io.println("  " + k + " = " + format_result(v))
        }
        i = i + 1
    }
}

fn try_assignment(input: string, env: map<string, float>): (map<string, float>, bool) {
    if (!string.starts_with(input, "let ")) {
        return (env, false)
    }
    let rest = string.trim(string.substring(input, 4, string.len(input)))
    match string.index_of(rest, "=") {
        none: {
            io.eprintln("Error: expected '=' in assignment")
            return (env, true)
        }
        some(eq_pos): {
            let var_name = string.trim(string.substring(rest, 0, eq_pos))
            let expr_str = string.trim(string.substring(rest, eq_pos + 1, string.len(rest)))
            if (string.len(var_name) == 0) {
                io.eprintln("Error: missing variable name")
                return (env, true)
            }
            if (string.len(expr_str) == 0) {
                io.eprintln("Error: missing expression after '='")
                return (env, true)
            }
            let value = eval_input(expr_str, env)
            let new_env = map.set(env, var_name, conv.string_to_float(value) ?? 0.0)
            io.println(var_name + " = " + value)
            return (new_env, true)
        }
    }
}

fn main(): none {
    let env: map<string, float>:mut = map.new()
    io.println("Flow Calculator — type 'help' for usage, 'quit' to exit")

    while (true) {
        io.print("> ")
        let line_opt = io.read_line()
        if (let none = line_opt) {
            io.println("")
            break
        }
        let trimmed = string.trim(line_opt ?? "")
        if (string.len(trimmed) == 0) {
            continue
        }
        if (trimmed == "quit") { break }
        if (trimmed == "exit") { break }
        if (trimmed == "help") {
            print_help()
            continue
        }
        if (trimmed == "clear") {
            env = map.new()
            io.println("Environment cleared")
            continue
        }
        if (trimmed == "vars") {
            print_vars(env)
            continue
        }

        let assign = try_assignment(trimmed, env)
        if (assign.1) {
            env = assign.0
            continue
        }

        io.println(eval_input(trimmed, env))
    }
}
