// healthcheck.flow — HTTP health checker
//
// Usage:
//   healthcheck [options] <url>...
//   healthcheck --demo
//
// Options:
//   --demo             Run against a built-in mock server
//   --timeout <ms>     Read timeout per request (default: 2000)
//   --retries <n>      Retry count on failure (default: 3)
//   --expected <code>  Default expected HTTP status (default: 200)
//
// URLs:
//   http://host:port/path    Full URL (port defaults to 80)
//   host:port/path           Shorthand without scheme
//
// Examples:
//   healthcheck http://localhost:8080/health http://localhost:8080/api/users
//   healthcheck --timeout 5000 --retries 5 http://10.0.0.1:3000/status
//   healthcheck --expected 204 http://api.example.com/healthz
//   healthcheck --demo
//
// Note: HTTP only. HTTPS is not supported.

module healthcheck

import io
import net
import string
import conv
import array
import time
import sys

// ============================================================================
// Data Types
// ============================================================================

type CheckStatus =
    | Pass(code: int)
    | Fail(msg: string)
    | Warn(code: int, reason: string)

type Config {
    urls: array<string>,
    timeout_ms: int,
    retries: int,
    expected_status: int,
    demo: bool
}

// ============================================================================
// URL Parsing (pure)
// ============================================================================

// Parse host from URL: "http://host:port/path" → "host"
fn:pure parse_host(url: string): string {
    let after_proto: string:mut = url
    if (let some(idx) = string.index_of(url, "://")) {
        after_proto = string.substring(url, idx + 3, string.len(url))
    }
    if (let some(colon) = string.index_of(after_proto, ":")) {
        return string.substring(after_proto, 0, colon)
    }
    if (let some(slash) = string.index_of(after_proto, "/")) {
        return string.substring(after_proto, 0, slash)
    }
    return after_proto
}

// Parse port from URL: "http://host:port/path" → port (default 80)
fn:pure parse_port(url: string): int {
    let after_proto: string:mut = url
    if (let some(idx) = string.index_of(url, "://")) {
        after_proto = string.substring(url, idx + 3, string.len(url))
    }
    if (let some(colon) = string.index_of(after_proto, ":")) {
        let after_colon = string.substring(after_proto, colon + 1, string.len(after_proto))
        if (let some(slash) = string.index_of(after_colon, "/")) {
            return conv.string_to_int(string.substring(after_colon, 0, slash)) ?? 80
        }
        return conv.string_to_int(after_colon) ?? 80
    }
    return 80
}

// Parse path from URL: "http://host:port/path" → "/path" (default "/")
fn:pure parse_path(url: string): string {
    let after_proto: string:mut = url
    if (let some(idx) = string.index_of(url, "://")) {
        after_proto = string.substring(url, idx + 3, string.len(url))
    }
    if (let some(slash) = string.index_of(after_proto, "/")) {
        return string.substring(after_proto, slash, string.len(after_proto))
    }
    return "/"
}

// Parse HTTP status code from response: "HTTP/1.0 200 OK..." → 200
fn:pure parse_http_status(response: string): int {
    if (let some(sp1) = string.index_of(response, " ")) {
        let after = string.substring(response, sp1 + 1, string.len(response))
        if (let some(sp2) = string.index_of(after, " ")) {
            return conv.string_to_int(string.substring(after, 0, sp2)) ?? 0
        }
        return conv.string_to_int(after) ?? 0
    }
    return 0
}

// ============================================================================
// Argument Parsing
// ============================================================================

fn parse_args(): Config {
    let args = sys.args()
    let argc = array.len_string(args)

    let timeout_ms: int:mut = 2000
    let retries: int:mut = 3
    let expected_status: int:mut = 200
    let demo: bool:mut = false
    let urls: array<string>:mut = []
    let skip_next: bool:mut = false

    let i: int:mut = 1
    while (i < argc) {
        let arg = array.get(args, i) ?? ""
        if (skip_next) {
            skip_next = false
            i = i + 1
        } else if (arg == "--demo") {
            demo = true
            i = i + 1
        } else if (arg == "--timeout") {
            if (i + 1 < argc) {
                timeout_ms = conv.string_to_int(array.get(args, i + 1) ?? "2000") ?? 2000
                skip_next = true
            }
            i = i + 1
        } else if (arg == "--retries") {
            if (i + 1 < argc) {
                retries = conv.string_to_int(array.get(args, i + 1) ?? "3") ?? 3
                skip_next = true
            }
            i = i + 1
        } else if (arg == "--expected") {
            if (i + 1 < argc) {
                expected_status = conv.string_to_int(array.get(args, i + 1) ?? "200") ?? 200
                skip_next = true
            }
            i = i + 1
        } else if (arg == "--help" || arg == "-h") {
            print_usage()
            sys.exit(0)
        } else if (string.starts_with(arg, "-")) {
            io.eprintln("Unknown option: " + arg)
            io.eprintln("Run with --help for usage.")
            sys.exit(1)
        } else {
            urls = array.push(urls, arg)
            i = i + 1
        }
    }

    if (!demo && array.len_string(urls) == 0) {
        io.eprintln("Error: no URLs provided. Use --demo or pass URLs.")
        io.eprintln("Run with --help for usage.")
        sys.exit(1)
    }

    return Config {
        urls: urls,
        timeout_ms: timeout_ms,
        retries: retries,
        expected_status: expected_status,
        demo: demo
    }
}

fn print_usage(): none {
    io.println("Usage: healthcheck [options] <url>...")
    io.println("       healthcheck --demo")
    io.println("")
    io.println("Options:")
    io.println("  --demo             Run against a built-in mock server")
    io.println("  --timeout <ms>     Read timeout per request (default: 2000)")
    io.println("  --retries <n>      Retry count on failure (default: 3)")
    io.println("  --expected <code>  Default expected HTTP status (default: 200)")
    io.println("  -h, --help         Show this help")
    io.println("")
    io.println("Examples:")
    io.println("  healthcheck http://localhost:8080/health")
    io.println("  healthcheck --timeout 5000 http://10.0.0.1:3000/status")
    io.println("  healthcheck --demo")
    io.println("")
    io.println("Note: HTTP only. HTTPS is not supported.")
}

// ============================================================================
// Mock HTTP Server (receivable coroutine for clean shutdown via message passing)
// ============================================================================

fn mock_server(inbox: stream<string>, port: int): stream<string> {
    match net.listen("127.0.0.1", port) {
        some(listener): {
            yield "ready"
            net.set_timeout(listener, 200)
            let running: bool:mut = true
            while (running) {
                for (cmd: string in inbox) {
                    if (cmd == "stop") {
                        running = false
                    }
                }
                if (!running) {
                    break
                }
                if (let some(client) = net.accept(listener)) {
                    if (let some(data) = net.read(client, 4096)) {
                        let request = string.from_bytes(data)
                        let response: string:mut = "HTTP/1.0 404 Not Found\r\n\r\nnot found"
                        if (string.contains(request, "GET /api/health")) {
                            response = "HTTP/1.0 200 OK\r\n\r\nok"
                        } else if (string.contains(request, "GET /api/users")) {
                            response = "HTTP/1.0 200 OK\r\n\r\n[users]"
                        }
                        net.write_string(client, response)
                    }
                    net.close(client)
                }
            }
            net.close(listener)
        }
        none: {
            yield "failed"
        }
    }
}

// ============================================================================
// Health Check Function
// Throws string exceptions for network failures (retry-worthy).
// Returns CheckStatus for HTTP outcomes.
// ============================================================================

fn check_url(host: string, port: int, url_path: string, expected: int, timeout: int): CheckStatus {
    let conn = net.connect(host, port)
    if (let some(sock) = conn) {
        net.set_timeout(sock, timeout)
        let req = "GET " + url_path + " HTTP/1.0\r\nHost: " + host + "\r\n\r\n"
        let wrote = net.write_string(sock, req)
        if (!wrote) {
            net.close(sock)
            throw "write failed"
        }
        let response = net.read(sock, 4096)
        if (let some(data) = response) {
            net.close(sock)
            let resp = string.from_bytes(data)
            let status_code = parse_http_status(resp)
            if (status_code == expected) {
                return Pass(status_code)
            }
            return Warn(status_code, "expected " + conv.to_string(expected) + " got " + conv.to_string(status_code))
        }
        net.close(sock)
        throw "timeout"
    }
    throw "connection failed"
}

// ============================================================================
// Result Aggregator (receivable coroutine)
// ============================================================================

fn result_aggregator(inbox: stream<string>): stream<string> {
    let p: int:mut = 0
    let f: int:mut = 0
    let w: int:mut = 0
    let finished: bool:mut = false

    while (!finished) {
        for (s: string in inbox) {
            if (s == "done") {
                finished = true
            } else if (s == "pass") {
                p = p + 1
            } else if (s == "fail") {
                f = f + 1
            } else if (s == "warn") {
                w = w + 1
            }
        }
        if (!finished) {
            time.sleep_ms(5)
        }
    }

    let total = p + f + w
    yield conv.to_string(p) + ":" + conv.to_string(f) + ":" + conv.to_string(w) + ":" + conv.to_string(total)
}

// ============================================================================
// Display
// ============================================================================

fn display_url(url: string): string {
    // Strip scheme for cleaner display
    if (let some(idx) = string.index_of(url, "://")) {
        return string.substring(url, idx + 3, string.len(url))
    }
    return url
}

// ============================================================================
// Check loop — shared between demo and real mode
// ============================================================================

fn run_checks(urls: array<string>, config: Config): none {
    let num_urls = array.len_string(urls)
    io.println("[HC] Starting health check for " + conv.to_string(num_urls) + " targets...")

    let agg :< result_aggregator()

    let idx: int:mut = 0
    while (idx < num_urls) {
        let url = array.get(urls, idx) ?? ""
        let host = parse_host(url)
        let port = parse_port(url)
        let url_path = parse_path(url)
        let label = display_url(url)

        io.println("[HC] Checking: " + label)

        try {
            let status = check_url(host, port, url_path, config.expected_status, config.timeout_ms)
            match status {
                Pass(code): {
                    io.println("[HC] OK: " + label + " (" + conv.to_string(code) + ")")
                    agg.send("pass")
                }
                Warn(code, reason): {
                    io.println("[HC] WARN: " + label + " (" + conv.to_string(code) + " - " + reason + ")")
                    agg.send("warn")
                }
                Fail(msg): {
                    io.println("[HC] FAIL: " + label + " (" + msg + ")")
                    agg.send("fail")
                }
            }
        } retry check_url (ex: string, attempts: config.retries) {
            io.println("[HC] RETRY: " + ex + ", retrying...")
        } catch (ex: string) {
            io.println("[HC] FAIL: " + label + " (" + ex + " after retries)")
            agg.send("fail")
        }

        idx = idx + 1
    }

    agg.send("done")

    match agg.next() {
        some(report_str): {
            let rparts = string.split(report_str, ":")
            io.println("[HC] --- Report ---")
            io.println("[HC] Passed: " + (array.get(rparts, 0) ?? "0"))
            io.println("[HC] Failed: " + (array.get(rparts, 1) ?? "0"))
            io.println("[HC] Warnings: " + (array.get(rparts, 2) ?? "0"))
            io.println("[HC] Total: " + (array.get(rparts, 3) ?? "0"))
        }
        none: {
            io.println("[HC] No report available")
        }
    }
}

// ============================================================================
// Main
// ============================================================================

fn main(): none {
    let config = parse_args()

    if (config.demo) {
        // Demo mode: start mock server and check built-in targets
        let demo_port = 39876
        let server :< mock_server(demo_port)

        match server.next() {
            some(status): {
                if (status != "ready") {
                    io.eprintln("[HC] Demo server failed to start")
                    sys.exit(1)
                }
            }
            none: {
                io.eprintln("[HC] Demo server failed to start")
                sys.exit(1)
            }
        }

        time.sleep_ms(50)

        let port_str = conv.to_string(demo_port)
        let bad_port_str = conv.to_string(demo_port + 1)
        let demo_urls: array<string>:mut = []
        demo_urls = array.push(demo_urls, "http://127.0.0.1:" + port_str + "/api/health")
        demo_urls = array.push(demo_urls, "http://127.0.0.1:" + port_str + "/api/users")
        demo_urls = array.push(demo_urls, "http://127.0.0.1:" + port_str + "/api/nothing")
        demo_urls = array.push(demo_urls, "http://127.0.0.1:" + bad_port_str + "/unreachable")

        run_checks(demo_urls, config)

        server.send("stop")
    } else {
        // Real mode: check user-provided URLs
        run_checks(config.urls, config)
    }
}
