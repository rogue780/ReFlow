module math

export fn:pure abs<T fulfills (Numeric, Comparable)>(n:T):T {
    let neg = n.negate()
    return if (n.compare(neg) < 0) { neg } else { n }
}

export fn:pure min<T fulfills Comparable>(a:T, b:T):T {
    return if (a.compare(b) <= 0) { a } else { b }
}

export fn:pure max<T fulfills Comparable>(a:T, b:T):T {
    return if (a.compare(b) >= 0) { a } else { b }
}

export fn:pure clamp<T fulfills Comparable>(val:T, lo:T, hi:T):T {
    return if (val.compare(lo) < 0) { lo } else { if (val.compare(hi) > 0) { hi } else { val } }
}

// Float-specific operations (inherently float, no generic equivalent)
export extern fn "fl_math_floor" floor(f:float):float
export extern fn "fl_math_ceil" ceil(f:float):float
export extern fn "fl_math_round" round(f:float):float
export extern fn "fl_math_pow" pow(base:float, exp:float):float
export extern fn "fl_math_sqrt" sqrt(f:float):float
export extern fn "fl_math_log" log(f:float):float
