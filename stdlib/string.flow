module string

export extern fn "fl_string_char_at" char_at(s:string, idx:int):char?
export extern fn "fl_string_substring" substring(s:string, start:int, end_idx:int):string
export extern fn "fl_string_index_of" index_of(s:string, needle:string):int?
export extern fn "fl_string_contains" contains(s:string, needle:string):bool
export extern fn "fl_string_starts_with" starts_with(s:string, prefix:string):bool
export extern fn "fl_string_ends_with" ends_with(s:string, suffix:string):bool
export extern fn "fl_string_split" split(s:string, sep:string):array<string>
export extern fn "fl_string_trim" trim(s:string):string
export extern fn "fl_string_trim_left" trim_left(s:string):string
export extern fn "fl_string_trim_right" trim_right(s:string):string
export extern fn "fl_string_replace" replace(s:string, old:string, new_str:string):string
export extern fn "fl_string_join" join(parts:array<string>, sep:string):string
export extern fn "fl_string_to_lower" to_lower(s:string):string
export extern fn "fl_string_to_upper" to_upper(s:string):string
export extern fn "fl_string_len" len(s:string):int
export extern fn "fl_string_to_bytes" to_bytes(s:string):array<byte>
export extern fn "fl_string_from_bytes" from_bytes(data:array<byte>):string
export extern fn "fl_string_repeat" repeat(s:string, n:int):string
export extern fn "fl_string_url_decode" url_decode(s:string):string
export extern fn "fl_string_url_encode" url_encode(s:string):string
export extern fn "fl_string_to_cptr" to_cptr(s:string):ptr
export extern fn "fl_string_from_cptr" from_cptr(p:ptr, len:int):string
