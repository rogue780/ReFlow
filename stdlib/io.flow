module io

export fn print(s: string): none = native "fl_print"
export fn println(s: string): none = native "fl_println"
export fn eprint(s: string): none = native "fl_eprint"
export fn eprintln(s: string): none = native "fl_eprintln"
export fn read_line(): string? = native "fl_read_line"
export fn read_byte(): byte? = native "fl_read_byte"
export fn read_stdin(): string? = native "fl_read_stdin"
export fn read_file(path: string): string? = native "fl_read_file"
export fn write_file(path: string, contents: string): bool = native "fl_write_file"
export fn tmpfile_create(suffix: string, contents: string): string = native "fl_tmpfile_create"
export fn tmpfile_remove(path: string): none = native "fl_tmpfile_remove"
export fn read_file_bytes(path: string): array<byte>? = native "fl_read_file_bytes"
export fn write_file_bytes(path: string, data: array<byte>): bool = native "fl_write_file_bytes"
export fn append_file(path: string, contents: string): bool = native "fl_append_file"
