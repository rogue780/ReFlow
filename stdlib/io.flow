module io

export extern fn "fl_print" print(s:string):none
export extern fn "fl_println" println(s:string):none
export extern fn "fl_eprint" eprint(s:string):none
export extern fn "fl_eprintln" eprintln(s:string):none
export extern fn "fl_read_line" read_line():string?
export extern fn "fl_read_byte" read_byte():byte?
export extern fn "fl_read_stdin" read_stdin():string?
export extern fn "fl_read_file" read_file(path:string):string?
export extern fn "fl_write_file" write_file(path:string, contents:string):bool
export extern fn "fl_tmpfile_create" tmpfile_create(suffix:string, contents:string):string
export extern fn "fl_tmpfile_remove" tmpfile_remove(path:string):none
export extern fn "fl_read_file_bytes" read_file_bytes(path:string):array<byte>?
export extern fn "fl_write_file_bytes" write_file_bytes(path:string, data:array<byte>):bool
export extern fn "fl_append_file" append_file(path:string, contents:string):bool
