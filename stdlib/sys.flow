module sys

export fn exit(code: int): none = native "fl_sys_exit"
export fn args(): array<string> = native "fl_sys_args"
export fn run_process(command: string, args: array<string>): int = native "fl_run_process"
export fn run_process_capture(command: string, args: array<string>): string? = native "fl_run_process_capture"
export fn env_get(name: string): string? = native "fl_env_get"
export fn clock_ms(): int64 = native "fl_clock_ms"
