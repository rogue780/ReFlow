module csv

// Parse full CSV string into rows of fields (RFC 4180)
export extern fn "fl_csv_parse" parse(s:string):array<array<string>>

// Parse a single CSV row
export extern fn "fl_csv_parse_row" parse_row(s:string):array<string>

// Generate CSV string from rows
export extern fn "fl_csv_to_string" to_string(rows:array<array<string>>):string

// Generate a single CSV row string
export extern fn "fl_csv_row_to_string" row_to_string(fields:array<string>):string

// Parse with custom delimiter
export extern fn "fl_csv_parse_delimited" parse_delimited(s:string, delimiter:byte):array<array<string>>

// Use first row as header names, returns array of maps
export extern fn "fl_csv_with_headers" with_headers(rows:array<array<string>>):array<map<string, string>>
