module csv

import string
import char
import array
import map

// --- Internal: parse CSV with given delimiter (RFC 4180 state machine) ---

fn parse_impl(s:string, delim:char):array<array<string>> {
    let len = string.len(s)
    let rows:array<array<string>>:mut = []
    let current_row:array<string>:mut = []
    let field:string:mut = ""
    // States: 0=FIELD_START, 1=UNQUOTED, 2=QUOTED, 3=QUOTED_QUOTE
    let state:int:mut = 0
    let i:int:mut = 0

    while (i < len) {
        let c_opt = string.char_at(s, i)
        match c_opt {
            some(c): {
                if (state == 0) {
                    // FIELD_START
                    if (c == '"') {
                        state = 2
                    } else if (c == delim) {
                        current_row = array.push(current_row, field)
                        field = ""
                    } else if (c == '\r') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                        if (i + 1 < len) {
                            match string.char_at(s, i + 1) {
                                some(nc): {
                                    if (nc == '\n') {
                                        i++
                                    }
                                }
                                none: {}
                            }
                        }
                    } else if (c == '\n') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                    } else {
                        field = field + char.to_string(c)
                        state = 1
                    }
                } else if (state == 1) {
                    // UNQUOTED
                    if (c == delim) {
                        current_row = array.push(current_row, field)
                        field = ""
                        state = 0
                    } else if (c == '\r') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                        if (i + 1 < len) {
                            match string.char_at(s, i + 1) {
                                some(nc): {
                                    if (nc == '\n') {
                                        i++
                                    }
                                }
                                none: {}
                            }
                        }
                        state = 0
                    } else if (c == '\n') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                        state = 0
                    } else {
                        field = field + char.to_string(c)
                    }
                } else if (state == 2) {
                    // QUOTED
                    if (c == '"') {
                        state = 3
                    } else {
                        field = field + char.to_string(c)
                    }
                } else {
                    // QUOTED_QUOTE (state == 3)
                    if (c == '"') {
                        // Doubled quote — emit single quote
                        field = field + "\""
                        state = 2
                    } else if (c == delim) {
                        current_row = array.push(current_row, field)
                        field = ""
                        state = 0
                    } else if (c == '\r') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                        if (i + 1 < len) {
                            match string.char_at(s, i + 1) {
                                some(nc): {
                                    if (nc == '\n') {
                                        i++
                                    }
                                }
                                none: {}
                            }
                        }
                        state = 0
                    } else if (c == '\n') {
                        current_row = array.push(current_row, field)
                        field = ""
                        rows = array.push(rows, current_row)
                        current_row = []
                        state = 0
                    } else {
                        // Character after closing quote (malformed) — treat as content
                        field = field + char.to_string(c)
                        state = 1
                    }
                }
            }
            none: {}
        }
        i++
    }

    // Finalize last field/row (unless we ended exactly on a newline)
    if (string.len(field) > 0 || state != 0 || array.size(current_row) > 0) {
        current_row = array.push(current_row, field)
        rows = array.push(rows, current_row)
    }

    return rows
}

// --- Internal: check if field needs quoting ---

fn needs_quoting(s:string, delim:char):bool {
    let len = string.len(s)
    let i:int:mut = 0
    while (i < len) {
        match string.char_at(s, i) {
            some(c): {
                if (c == delim || c == '"' || c == '\n' || c == '\r') {
                    return true
                }
            }
            none: {}
        }
        i++
    }
    return false
}

// --- Internal: quote a single field ---

fn quote_field(s:string):string {
    let len = string.len(s)
    let result:string:mut = "\""
    let i:int:mut = 0
    while (i < len) {
        match string.char_at(s, i) {
            some(c): {
                if (c == '"') {
                    result = result + "\"\""
                } else {
                    result = result + char.to_string(c)
                }
            }
            none: {}
        }
        i++
    }
    result = result + "\""
    return result
}

// --- Public API ---

// Parse full CSV string into rows of fields (RFC 4180)
export fn parse(s:string):array<array<string>> {
    return parse_impl(s, ',')
}

// Parse a single CSV row
export fn parse_row(s:string):array<string> {
    let rows = parse_impl(s, ',')
    if (array.size(rows) > 0) {
        match array.get_any(rows, 0) {
            some(row): { return row }
            none: { return [] }
        }
    }
    return []
}

// Generate CSV string from rows
export fn to_string(rows:array<array<string>>):string {
    let n = array.size(rows)
    let result:string:mut = ""
    let i:int:mut = 0
    while (i < n) {
        if (i > 0) {
            result = result + "\r\n"
        }
        let row = array.get_any(rows, i) ?? []
        result = result + row_to_string(row)
        i++
    }
    return result
}

// Generate a single CSV row string
export fn row_to_string(fields:array<string>):string {
    let n = array.size(fields)
    let result:string:mut = ""
    let i:int:mut = 0
    while (i < n) {
        if (i > 0) {
            result = result + ","
        }
        let f = array.get(fields, i) ?? ""
        if (needs_quoting(f, ',')) {
            result = result + quote_field(f)
        } else {
            result = result + f
        }
        i++
    }
    return result
}

// Parse with custom delimiter
export fn parse_delimited(s:string, delimiter:byte):array<array<string>> {
    return parse_impl(s, cast<char>(delimiter))
}

// Use first row as header names, returns array of maps
export fn with_headers(rows:array<array<string>>):array<map<string, string>> {
    let nrows = array.size(rows)
    if (nrows < 1) {
        return []
    }

    let headers:array<string>:mut = []
    match array.get_any(rows, 0) {
        some(h): { headers = h }
        none: { return [] }
    }
    let ncols = array.size(headers)

    let result:array<map<string, string>>:mut = []
    let i:int:mut = 1
    while (i < nrows) {
        let row = array.get_any(rows, i) ?? []
        let m:map<string, string>:mut = map.new()
        let row_len = array.size(row)
        let j:int:mut = 0
        while (j < ncols) {
            let key = array.get(headers, j) ?? ""
            let val = if (j < row_len) { array.get(row, j) ?? "" } else { "" }
            m = map.set(m, key, val)
            j++
        }
        result = array.push(result, m)
        i++
    }
    return result
}
