module time

extern type DateTime

export extern fn "fl_time_unix_timestamp" now():int64
export extern fn "fl_time_unix_timestamp_ms" now_ms():int64
export extern fn "fl_time_sleep_ms" sleep_ms(ms:int):none

// DateTime construction
export extern fn "fl_time_datetime_now" datetime_now():DateTime
export extern fn "fl_time_datetime_utc" datetime_utc():DateTime

// Formatting
export extern fn "fl_time_format_iso8601" format_iso8601(dt:DateTime):string
export extern fn "fl_time_format_rfc2822" format_rfc2822(dt:DateTime):string
export extern fn "fl_time_format_http" format_http(dt:DateTime):string

// Component accessors
export extern fn "fl_time_year" year(dt:DateTime):int
export extern fn "fl_time_month" month(dt:DateTime):int
export extern fn "fl_time_day" day(dt:DateTime):int
export extern fn "fl_time_hour" hour(dt:DateTime):int
export extern fn "fl_time_minute" minute(dt:DateTime):int
export extern fn "fl_time_second" second(dt:DateTime):int
