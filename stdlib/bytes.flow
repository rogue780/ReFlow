module bytes

export extern fn "fl_string_to_bytes" from_string(s:string):array<byte>
export extern fn "fl_string_from_bytes" to_string(data:array<byte>):string
export extern fn "fl_bytes_slice" slice(data:array<byte>, start:int64, end_idx:int64):array<byte>
export extern fn "fl_bytes_concat" concat(a:array<byte>, b:array<byte>):array<byte>
export extern fn "fl_bytes_len" len(data:array<byte>):int64
