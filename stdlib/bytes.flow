module bytes

export fn:pure from_string(s: string): array<byte> = native "fl_string_to_bytes"
export fn:pure to_string(data: array<byte>): string = native "fl_string_from_bytes"
export fn:pure slice(data: array<byte>, start: int64, end_idx: int64): array<byte> = native "fl_bytes_slice"
export fn:pure concat(a: array<byte>, b: array<byte>): array<byte> = native "fl_bytes_concat"
export fn:pure len(data: array<byte>): int64 = native "fl_bytes_len"
