module char

export extern fn "fl_char_is_digit" is_digit(c:char):bool
export extern fn "fl_char_is_alpha" is_alpha(c:char):bool
export extern fn "fl_char_is_alphanumeric" is_alphanumeric(c:char):bool
export extern fn "fl_char_is_whitespace" is_whitespace(c:char):bool
export extern fn "fl_char_to_int" to_code(c:char):int
export extern fn "fl_int_to_char" from_code(n:int):char
export extern fn "fl_char_to_string" to_string(c:char):string
