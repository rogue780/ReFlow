module net

extern type Socket

export extern fn "fl_net_listen" listen(host:string, port:int):Socket?
export extern fn "fl_net_accept" accept(sock:Socket):Socket?
export extern fn "fl_net_connect" connect(host:string, port:int):Socket?
export extern fn "fl_net_read" read(sock:Socket, max_bytes:int):array<byte>?
export extern fn "fl_net_write" write(sock:Socket, data:array<byte>):bool
export extern fn "fl_net_write_string" write_string(sock:Socket, s:string):bool
export extern fn "fl_net_close" close(sock:Socket):none
export extern fn "fl_net_set_timeout" set_timeout(sock:Socket, ms:int):bool
export extern fn "fl_net_remote_addr" remote_addr(sock:Socket):string?
export extern fn "fl_net_fd" fd(sock:Socket):int
export extern fn "fl_net_write_string_fd" write_to_fd(fd:int, msg:string):bool
