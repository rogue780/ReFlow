module testing

export fn assert_true(val:bool, msg:string):void {
    if (!val) {
        throw "assertion failed (expected true): " + msg
    }
}

export fn assert_false(val:bool, msg:string):void {
    if (val) {
        throw "assertion failed (expected false): " + msg
    }
}

export fn fail(msg:string):void {
    throw msg
}

export fn assert_eq<T fulfills (Equatable, Showable)>(expected:T, actual:T, msg:string):void {
    if (!expected.equals(actual)) {
        let detail = f"expected {expected.to_string()}, got {actual.to_string()}"
        fail(f"{msg}: {detail}")
    }
}
