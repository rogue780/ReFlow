module testing

export extern fn "fl_test_assert_true" assert_true(val:bool, msg:string):void
export extern fn "fl_test_assert_false" assert_false(val:bool, msg:string):void
export extern fn "fl_test_fail" fail(msg:string):void

export fn assert_eq<T fulfills (Equatable, Showable)>(expected:T, actual:T, msg:string):void {
    if (!expected.equals(actual)) {
        let detail = f"expected {expected.to_string()}, got {actual.to_string()}"
        fail(f"{msg}: {detail}")
    }
}
