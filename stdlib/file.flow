module file

extern type file

export extern fn "fl_file_open_read" open_read(path:string):file?
export extern fn "fl_file_open_write" open_write(path:string):file?
export extern fn "fl_file_open_append" open_append(path:string):file?
export extern fn "fl_file_open_read_bytes" open_read_bytes(path:string):file?
export extern fn "fl_file_open_write_bytes" open_write_bytes(path:string):file?
export extern fn "fl_file_close" close(f:file):none
export extern fn "fl_file_read_bytes" read_bytes(f:file, n:int):array<byte>?
export extern fn "fl_file_read_line" read_line(f:file):string?
export extern fn "fl_file_read_all" read_all(f:file):string?
export extern fn "fl_file_read_all_bytes" read_all_bytes(f:file):array<byte>?
export extern fn "fl_file_write_bytes" write_bytes(f:file, data:array<byte>):bool
export extern fn "fl_file_write_string" write_string(f:file, s:string):bool
export extern fn "fl_file_flush" flush(f:file):bool
export extern fn "fl_file_seek" seek(f:file, offset:int64):bool
export extern fn "fl_file_seek_end" seek_end(f:file, offset:int64):bool
export extern fn "fl_file_position" position(f:file):int64
export extern fn "fl_file_size" size(f:file):int64
