module array

// Type-specific getters
export extern fn "fl_array_get_int" get_int(arr:array<int>, idx:int):int?
export extern fn "fl_array_get_int64" get_int64(arr:array<int64>, idx:int):int64?
export extern fn "fl_array_get_float" get_float(arr:array<float>, idx:int):float?
export extern fn "fl_array_get_bool" get_bool(arr:array<bool>, idx:int):bool?
export extern fn "fl_array_get_safe" get(arr:array<string>, idx:int):string?

// Generic get — works for pointer/heap types (string, Coroutine, etc.)
export extern fn "fl_array_get_safe" get_any<T>(arr:array<T>, idx:int):T?

// Type-specific lengths
export extern fn "fl_array_len_int" len(arr:array<int>):int
export extern fn "fl_array_len_int" len_string(arr:array<string>):int
export extern fn "fl_array_len_int" len_float(arr:array<float>):int
export extern fn "fl_array_len_int" len_bool(arr:array<bool>):int
export extern fn "fl_array_len_int" len_byte(arr:array<byte>):int
export extern fn "fl_array_len" len64(arr:array<int>):int64

// Generic len — works for any element type
export extern fn "fl_array_len_int" size<T>(arr:array<T>):int

// Type-specific concat
export extern fn "fl_array_concat" concat_int(a:array<int>, b:array<int>):array<int>
export extern fn "fl_array_concat" concat_string(a:array<string>, b:array<string>):array<string>
export extern fn "fl_array_concat" concat_byte(a:array<byte>, b:array<byte>):array<byte>

// Generic concat
export extern fn "fl_array_concat" concat<T>(a:array<T>, b:array<T>):array<T>

// Generic push — works for pointer/heap types (string, Coroutine, etc.)
export extern fn "fl_array_push_ptr" push<T>(arr:array<T>, val:T):array<T>

// Value-type push functions
export extern fn "fl_array_push_int" push_int(arr:array<int>, val:int):array<int>
export extern fn "fl_array_push_int64" push_int64(arr:array<int64>, val:int64):array<int64>
export extern fn "fl_array_push_float" push_float(arr:array<float>, val:float):array<float>
export extern fn "fl_array_push_bool" push_bool(arr:array<bool>, val:bool):array<bool>
export extern fn "fl_array_push_byte" push_byte(arr:array<byte>, val:byte):array<byte>
