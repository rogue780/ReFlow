; sys_demo.flow — Demonstrates the sys module
module examples.sys_demo

import io (println)
import sys (args, env_get, clock_ms)
import conv (int64_to_string)

fn main() {
    ; Command line args
    let argv: array<string> = args()
    println(f"Program: {argv[0]}")

    ; Environment variable
    match env_get("HOME") {
        some(home) -> println(f"HOME = {home}")
        none -> println("HOME is not set")
    }

    match env_get("NONEXISTENT_VAR") {
        some(val) -> println(f"Found: {val}")
        none -> println("NONEXISTENT_VAR is not set (expected)")
    }

    ; Timing
    let start: int64 = clock_ms()
    ; Do some work
    let sum: int:mut = 0
    let i: int:mut = 0
    while i < 1000000 {
        sum = sum + i
        i = i + 1
    }
    let elapsed: int64 = clock_ms() - start
    println(f"Computed sum in {int64_to_string(elapsed)}ms")
}
