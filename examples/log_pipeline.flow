; app_log_pipeline.flow — Log ingestion pipeline
; Exercises: records, pattern matching on strings, sequential fan-out,
; try/catch with continue, string parsing, multiple sinks
module tests.app_log_pipeline

import io (println)
import string
import array
import conv

; --- Types ---

type Severity {
    level: int
    name: string
}

type LogEntry {
    timestamp: string
    severity: Severity
    source: string
    message: string
}

; --- Severity constructors ---

fn:pure make_severity(name: string): Severity {
    if name == "ERROR" { return Severity { level: 0, name: "ERROR" } }
    if name == "WARN"  { return Severity { level: 1, name: "WARN" } }
    if name == "INFO"  { return Severity { level: 2, name: "INFO" } }
    return Severity { level: 3, name: "DEBUG" }
}

; --- Parsers for different log formats ---

fn:pure parse_kv_log(line: string): LogEntry {
    ; Format: "ts=TIMESTAMP level=LEVEL src=SOURCE msg=MESSAGE"
    let parts = string.split(line, " ")
    let ts = string.replace(array.get(parts, 0) ?? "", "ts=", "")
    let level = string.replace(array.get(parts, 1) ?? "", "level=", "")
    let src = string.replace(array.get(parts, 2) ?? "", "src=", "")
    let msg = string.replace(array.get(parts, 3) ?? "", "msg=", "")
    return LogEntry {
        timestamp: ts,
        severity: make_severity(level),
        source: src,
        message: msg
    }
}

fn:pure parse_csv_log(line: string): LogEntry {
    ; Format: "TIMESTAMP,LEVEL,SOURCE,MESSAGE"
    let parts = string.split(line, ",")
    return LogEntry {
        timestamp: array.get(parts, 0) ?? "",
        severity: make_severity(array.get(parts, 1) ?? ""),
        source: array.get(parts, 2) ?? "",
        message: array.get(parts, 3) ?? ""
    }
}

fn:pure parse_simple_log(line: string): LogEntry {
    ; Format: "TIMESTAMP SOURCE LEVEL MESSAGE"
    let parts = string.split(line, " ")
    return LogEntry {
        timestamp: array.get(parts, 0) ?? "",
        severity: make_severity(array.get(parts, 2) ?? ""),
        source: array.get(parts, 1) ?? "",
        message: array.get(parts, 3) ?? ""
    }
}

; --- Format detection and dispatch ---

fn:pure detect_and_parse(line: string): LogEntry {
    if string.starts_with(line, "ts=") {
        return parse_kv_log(line)
    }
    if string.contains(line, ",") {
        return parse_csv_log(line)
    }
    return parse_simple_log(line)
}

; --- Fan-out sinks ---

fn:pure write_archive(entry: LogEntry): string {
    return "ARCHIVE: [" + entry.timestamp + "] " + entry.source + " " + entry.message
}

fn:pure update_stats(entry: LogEntry): string {
    return "STATS: severity=" + entry.severity.name + " source=" + entry.source
}

fn:pure combine_output(archived: string, stats: string): string {
    return archived + "\n" + stats
}

; --- Main ---

fn main() {
    let lines = [
        "ts=2024-01-01 level=ERROR src=api msg=timeout",
        "2024-01-01,INFO,db,connected",
        "2024-01-01 web WARN slow_query",
        "corrupt???",
        "ts=2024-01-02 level=WARN src=api msg=retry"
    ]

    for (line: string in lines) {
        try {
            let entry = detect_and_parse(line)
            ; Validate: timestamp and source must be present
            if string.len(entry.timestamp) == 0 {
                throw "empty timestamp"
            }
            if string.len(entry.source) == 0 {
                throw "empty source"
            }
            ; Sequential fan-out: two sinks process each entry
            let output = entry -> (write_archive | update_stats) -> combine_output
            println(output)
            ; Print filtered: only severity ERROR or WARN
            if entry.severity.level <= 1 {
                println("ALERT: " + entry.severity.name + " from " + entry.source + ": " + entry.message)
            }
        } catch (e: string) {
            println("SKIP: " + e)
        }
    }
}
