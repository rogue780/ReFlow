module net_demo

// net_demo.flow — TCP networking with the net module.
//
// Demonstrates: listen on a random port, accept a connection,
// query the remote address, and close sockets.

import net
import io

fn main(): void {
    // Start a TCP listener on loopback with an OS-assigned port.
    // Port 0 tells the OS to pick an available port.
    let listener = net.listen("127.0.0.1", 0)
    match listener {
        some(srv): {
            io.println("Listening on 127.0.0.1 (random port)")

            // Accept would block waiting for a connection, so we
            // just demonstrate the listen/close lifecycle here.
            // Full send/receive is tested at the C level in test_net.c.

            // Close the listener socket
            net.close(srv)
            io.println("Server closed")
        }
        none: io.println("Listen failed")
    }

    // Demonstrate connect to a non-listening port returns none
    let conn = net.connect("127.0.0.1", 1)
    match conn {
        some(c): {
            io.println("unexpected connect success")
            net.close(c)
        }
        none: io.println("Connect to port 1 returned none (expected)")
    }

    io.println("net demo done")
}
