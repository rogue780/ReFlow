// composition.flow — Composition chains, fan-out, multi-arity
module examples.composition

import io (println)

fn:pure double(x: int): int = x * 2
fn:pure triple(x: int): int = x * 3
fn:pure square(x: int): int = x * x
fn:pure add(x: int, y: int): int = x + y
fn:pure mul(x: int, y: int): int = x * y
fn:pure negate(x: int): int = 0 - x

fn main() {
    // Linear chain: 5 -> double -> square
    // Equivalent to: square(double(5)) = square(10) = 100
    let a: int = 5 -> double -> square
    println(f"5 -> double -> square = {a}")

    // Fan-out: 5 -> (double | square) -> add
    // Equivalent to: add(double(5), square(5)) = add(10, 25) = 35
    let b: int = 5 -> (double | square) -> add
    println(f"5 -> (double | square) -> add = {b}")

    // Fan-out with different functions
    // 4 -> (double | triple) -> mul
    // Equivalent to: mul(double(4), triple(4)) = mul(8, 12) = 96
    let c: int = 4 -> (double | triple) -> mul
    println(f"4 -> (double | triple) -> mul = {c}")

    // Longer chain: 3 -> double -> square -> negate
    // Equivalent to: negate(square(double(3))) = negate(36) = -36
    let d: int = 3 -> double -> square -> negate
    println(f"3 -> double -> square -> negate = {d}")

    // Multi-value chain: two inputs to a binary function
    // 3 -> 4 -> add -> double
    // Equivalent to: double(add(3, 4)) = double(7) = 14
    let e: int = 3 -> 4 -> add -> double
    println(f"3 -> 4 -> add -> double = {e}")
}
