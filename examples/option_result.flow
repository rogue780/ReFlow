// option_result.flow — Option, Result, pattern matching, ??, ? propagation
module examples.option_result

import io (println)

// Function returning option
fn find_index(arr: array<int>, target: int): int? {
    let i: int:mut = 0
    for (x: int in arr) {
        if (x == target) {
            return some(i)
        }
        i++
    }
    return none
}

// Using ?? null coalescing
fn find_or_default(arr: array<int>, target: int): int {
    let idx = find_index(arr, target) ?? -1
    return idx
}

// Function returning result
fn safe_divide(a: int, b: int): result<int, string> {
    if (b == 0) {
        return err("division by zero")
    }
    return ok(a / b)
}

// Using ? propagation
fn compute(x: int, y: int): result<int, string> {
    let quotient = safe_divide(x, y)?
    return ok(quotient + 1)
}

fn main() {
    let nums = [10, 20, 30, 40, 50]

    // Option matching
    match find_index(nums, 30) {
        some(i): println(f"found 30 at index {i}")
        none: println("30 not found")
    }

    match find_index(nums, 99) {
        some(i): println(f"found 99 at index {i}")
        none: println("99 not found")
    }

    // Null coalescing
    let idx = find_or_default(nums, 20)
    println(f"index of 20: {idx}")
    let missing = find_or_default(nums, 99)
    println(f"index of 99: {missing}")

    // Auto-lifting: int assigned to int?
    let maybe: int? = 42
    match maybe {
        some(v): println(f"auto-lifted: {v}")
        none: println("none")
    }

    // Result matching
    match safe_divide(10, 3) {
        ok(v): println(f"10 / 3 = {v}")
        err(msg): println(f"error: {msg}")
    }

    match safe_divide(10, 0) {
        ok(v): println(f"10 / 0 = {v}")
        err(msg): println(f"error: {msg}")
    }

    // ? propagation
    match compute(10, 3) {
        ok(v): println(f"compute(10, 3) = {v}")
        err(msg): println(f"compute error: {msg}")
    }

    match compute(10, 0) {
        ok(v): println(f"compute(10, 0) = {v}")
        err(msg): println(f"compute error: {msg}")
    }
}
