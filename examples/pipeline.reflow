; pipeline.reflow — Composition chain example
module examples.pipeline

import io (println)

pure fn double(x: int): int = x * 2
pure fn square(x: int): int = x * x
pure fn add(x: int, y: int): int = x + y

fn main() {
    ; x -> (double | square) -> add
    ; equivalent to: add(double(5), square(5))
    let result: int = 5 -> (double | square) -> add
    println(f"result = {result}")
}
