// path_demo.flow — Demonstrates the path module
module examples.path_demo

import io (println)
import path (join, stem, parent, with_suffix, cwd, resolve, exists, is_dir, is_file, extension, list_dir)

fn main() {
    // Existing path functions
    let working_dir: string = cwd()
    println(f"cwd: {working_dir}")
    println(f"join: {join(working_dir, \"src\")}")
    println(f"stem of 'main.flow': {stem(\"main.flow\")}")
    println(f"parent of 'foo/bar.txt': {parent(\"foo/bar.txt\")}")
    println(f"with_suffix 'foo.txt' '.md': {with_suffix(\"foo.txt\", \".md\")}")
    println(f"exists '.': {exists(\".\")}")

    // New path functions
    println(f"is_dir '.': {is_dir(\".\")}")
    println(f"is_file 'Makefile': {is_file(\"Makefile\")}")

    match extension("hello.flow") {
        some(ext) -> println(f"extension of 'hello.flow': {ext}")
        none -> println("no extension")
    }

    match list_dir(".") {
        some(entries) -> println(f"entries in '.': found some files")
        none -> println("could not list directory")
    }
}
