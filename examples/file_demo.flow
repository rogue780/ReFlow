module file_demo

import io
import file

fn main(): none =
  // Write a file using handle-based I/O
  let path = "/tmp/flow_file_demo.txt"
  let wf = file.open_write(path)
  match wf
    | some(f) ->
      file.write_string(f, "Hello from Flow file handles!\n")
      file.write_string(f, "Line two\n")
      file.write_string(f, "Line three\n")
      file.flush(f)
      file.close(f)
      io.println("Wrote 3 lines to " ++ path)
    | none -> io.println("Failed to open file for writing")

  // Read it back
  let rf = file.open_read(path)
  match rf
    | some(f) ->
      let content = file.read_all(f)
      match content
        | some(s) -> io.println("Read back: " ++ s)
        | none -> io.println("Failed to read content")
      file.close(f)
    | none -> io.println("Failed to open file for reading")

  // Read line by line
  let rf2 = file.open_read(path)
  match rf2
    | some(f) ->
      io.println("Reading line by line:")
      let line1 = file.read_line(f)
      match line1
        | some(l) -> io.println("  Line 1: " ++ l)
        | none -> io.println("  (no more lines)")
      let line2 = file.read_line(f)
      match line2
        | some(l) -> io.println("  Line 2: " ++ l)
        | none -> io.println("  (no more lines)")
      file.close(f)
    | none -> io.println("Failed to open file for line reading")

  // Check file size
  let rf3 = file.open_read(path)
  match rf3
    | some(f) ->
      let sz = file.size(f)
      io.println("File size: " ++ int_to_string(sz))
      file.close(f)
    | none -> io.println("Failed to open file for size check")
