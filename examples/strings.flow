; strings.flow — String operations, f-strings, concatenation, comparison
module examples.strings

import io (println)

fn repeat(s: string, n: int): string {
    let result: string:mut = ""
    let i: int:mut = 0
    while (i < n) {
        result = result + s
        i++
    }
    return result
}

fn main() {
    ; String literals
    let name = "Flow"
    let version = "0.1"

    ; F-string interpolation
    println(f"{name} v{version}")

    ; F-string with expressions
    let x = 42
    let half = x / 2
    println(f"{x} / 2 = {half}")

    ; String concatenation
    let full = name + " " + "Language"
    println(full)

    ; String comparison
    let a = "hello"
    let b = "hello"
    let c = "world"
    println(f"a == b: {a == b}")
    println(f"a == c: {a == c}")

    ; Repeated string building
    let stars = repeat("*", 10)
    println(stars)

    ; Nested f-string expressions
    let temp = 72
    let unit = "F"
    println(f"Temperature: {temp} degrees {unit}")
}
