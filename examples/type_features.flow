; type_features.flow — Cast, typeof, copy
module examples.type_features

import io (println)

fn main() {
    ; typeof — compile-time type name as string
    let x = 42
    let t = typeof(x)
    println(f"typeof(42) = {t}")

    let s = "hello"
    println(f"typeof(s) = {typeof(s)}")

    ; cast — numeric type conversion
    let big: int64 = cast<int64>(x)
    println(f"cast<int64>(42) = {big}")

    let small: int = 100
    let as_float: float = cast<float>(small)
    println(f"cast<float>(100) = {as_float}")

    ; @ copy operator
    let original = "hello"
    let copied = @original
    println(f"original={original}, copy={copied}")
    println(f"equal: {original == copied}")
}
