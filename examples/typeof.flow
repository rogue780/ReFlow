; typeof.flow — Runtime type introspection with typeof()
module examples.typeof_demo

import io (println)

fn show_type(label: string, type_name: string) {
    println(f"{label}: {type_name}")
}

fn main() {
    ; typeof() returns a string representation of the expression's type
    ; It is evaluated at compile time and emitted as a string literal

    ; Primitive types
    let x = 42
    show_type("integer", typeof(x))

    let f = 3.14
    show_type("float", typeof(f))

    let b = true
    show_type("boolean", typeof(b))

    let s = "hello"
    show_type("string", typeof(s))

    ; Composite types
    let pair = (1, 2)
    show_type("tuple", typeof(pair))

    ; typeof in expressions
    println(f"The type of 42 is: {typeof(x)}")
}
