// Self-test example: exercises testing, conv, string, and math modules.
// This program runs assertions and prints the results.
// If any assertion fails, the program exits with an error.

import testing
import conv
import math
import io

fn main(): void {
    io.println("Running self-tests...")

    // Math module tests
    testing.assert_eq(5, math.abs(-5), "abs(-5) should be 5")
    testing.assert_eq(0, math.abs(0), "abs(0) should be 0")
    testing.assert_eq(3, math.min(3, 7), "min(3, 7) should be 3")
    testing.assert_eq(7, math.max(3, 7), "max(3, 7) should be 7")
    testing.assert_eq(5, math.clamp(10, 1, 5), "clamp(10, 1, 5) should be 5")
    testing.assert_eq(1, math.clamp(-3, 1, 5), "clamp(-3, 1, 5) should be 1")
    testing.assert_eq(3, math.clamp(3, 1, 5), "clamp(3, 1, 5) should be 3")

    // Conv module tests
    testing.assert_eq("42", conv.to_string(42), "to_string(42)")
    testing.assert_eq("-1", conv.to_string(-1), "to_string(-1)")
    testing.assert_eq("true", conv.to_string(true), "to_string(true)")
    testing.assert_eq("false", conv.to_string(false), "to_string(false)")

    // Boolean logic tests
    testing.assert_true(true, "true should be true")
    testing.assert_false(false, "false should be false")
    testing.assert_eq(true, 1 == 1, "1 == 1 should be true")
    testing.assert_eq(false, 1 == 2, "1 == 2 should be false")

    io.println("All self-tests passed!")
}
