// basics.flow — Primitive types, let bindings, arithmetic, comparisons
module examples.basics

import io (println)

fn main() {
    // Integer types and arithmetic
    let a: int = 42
    let b: int = 10
    let sum = a + b
    let diff = a - b
    let product = a * b
    let quotient = a / b
    let remainder = a % b

    println(f"sum={sum}, diff={diff}, product={product}")
    println(f"quotient={quotient}, remainder={remainder}")

    // Float arithmetic
    let pi: float = 3.14159
    let radius: float = 5.0
    let area = pi * radius * radius
    println(f"area={area}")

    // Boolean and logical operators
    let t: bool = true
    let f: bool = false
    let and_result = t && f
    let or_result = t || f
    let not_result = !t
    println(f"and={and_result}, or={or_result}, not={not_result}")

    // Comparisons
    let lt = a < 100
    let gt = a > 100
    let eq = a == 42
    let neq = a != 0
    println(f"lt={lt}, gt={gt}, eq={eq}, neq={neq}")

    // Mutable variables and update operators
    let x: int:mut = 0
    x += 10
    x -= 3
    x *= 2
    println(f"after updates: x={x}")

    x++
    println(f"after increment: x={x}")

    x--
    println(f"after decrement: x={x}")

    // Ternary expression
    let max = a > b ? a : b
    println(f"max of {a} and {b} is {max}")

    // Unary negation
    let neg = -a
    println(f"negation of {a} is {neg}")

    // String concatenation
    let greeting = "Hello" + ", " + "World!"
    println(greeting)
}
