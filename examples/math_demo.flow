// math_demo.flow — Demonstrates the math module
module examples.math_demo

import io (println)
import math (abs_int, abs_float, min_int, max_int, min_float, max_float, clamp_int, floor, ceil, round, pow, sqrt, log)

fn main() {
    // Absolute value
    println(f"abs_int(-42) = {abs_int(-42)}")
    println(f"abs_float(-3.14) = {abs_float(-3.14)}")

    // Min/Max
    println(f"min_int(3, 7) = {min_int(3, 7)}")
    println(f"max_int(3, 7) = {max_int(3, 7)}")
    println(f"min_float(1.5, 2.5) = {min_float(1.5, 2.5)}")
    println(f"max_float(1.5, 2.5) = {max_float(1.5, 2.5)}")

    // Clamp
    println(f"clamp_int(15, 0, 10) = {clamp_int(15, 0, 10)}")
    println(f"clamp_int(5, 0, 10) = {clamp_int(5, 0, 10)}")

    // Rounding
    println(f"floor(3.7) = {floor(3.7)}")
    println(f"ceil(3.2) = {ceil(3.2)}")
    println(f"round(3.5) = {round(3.5)}")

    // Power and roots
    println(f"pow(2.0, 10.0) = {pow(2.0, 10.0)}")
    println(f"sqrt(144.0) = {sqrt(144.0)}")
    println(f"log(1.0) = {log(1.0)}")
}
