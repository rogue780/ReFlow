; pipeline.flow — Composition chain example
module examples.pipeline

import io (println)

fn:pure double(x: int): int = x * 2
fn:pure square(x: int): int = x * x
fn:pure add(x: int, y: int): int = x + y

fn main() {
    ; x -> (double | square) -> add
    ; equivalent to: add(double(5), square(5))
    let result: int = 5 -> (double | square) -> add
    println(f"result = {result}")
}
