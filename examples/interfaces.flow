// interfaces.flow — Interface contracts and fulfillment validation
module examples.interfaces

import io (println)

// --- Basic interface ---
// An interface declares method signatures that types must implement

interface Printable {
    fn to_string(self): string
}

// A type fulfills an interface by declaring all required methods

type Color fulfills Printable {
    r: int
    g: int
    b: int

    fn to_string(self): string {
        return f"rgb({self.r}, {self.g}, {self.b})"
    }
}

type Point fulfills Printable {
    x: float
    y: float

    fn to_string(self): string {
        return f"({self.x}, {self.y})"
    }
}

// --- Pure interface ---
// Interfaces can require methods to be pure

interface Hashable {
    fn:pure hash(self): int
}

type Pixel fulfills Hashable {
    x: int
    y: int

    fn:pure hash(self): int {
        return self.x * 31 + self.y
    }
}

// --- Generic interface (Exception<T>) ---
// Exception<T> is a builtin interface requiring message(), data(), original()

type AppError fulfills Exception<string> {
    msg: string
    detail: string

    fn message(self): string {
        return self.msg
    }

    fn data(self): string {
        return self.detail
    }

    fn original(self): string {
        return self.msg
    }
}

// --- Multiple methods ---

interface Describable {
    fn name(self): string,
    fn describe(self): string
}

type Animal fulfills Describable {
    species: string
    sound: string

    fn name(self): string {
        return self.species
    }

    fn describe(self): string {
        return f"The {self.species} goes {self.sound}"
    }
}

fn main() {
    // Basic fulfillment
    let red = Color { r: 255, g: 0, b: 0 }
    println(red.to_string())

    let origin = Point { x: 0.0, y: 0.0 }
    println(origin.to_string())

    // Pure interface fulfillment
    let px = Pixel { x: 10, y: 20 }
    println(f"hash: {px.hash()}")

    // Exception<T> fulfillment
    let app_err = AppError { msg: "oops", detail: "something broke" }
    println(f"error: {app_err.message()}")
    println(f"data: {app_err.data()}")

    // Multiple methods
    let dog = Animal { species: "Dog", sound: "woof" }
    println(dog.describe())
}
