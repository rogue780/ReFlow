// lambdas.flow — Lambda expressions, closures, and higher-order functions
module examples.lambdas

import io (println)

// Higher-order function: takes a function and applies it
fn apply(f: fn(int): int, x: int): int {
    return f(x)
}

// Higher-order: applies a function twice
fn apply_twice(f: fn(int): int, x: int): int {
    return f(f(x))
}

// Returns a closure that adds a fixed offset
fn make_adder(n: int): fn(int): int {
    return \(x: int => x + n)
}

fn triple(x: int): int = x * 3

fn main() {
    // --- Basic lambdas ---
    let inc = \(x: int => x + 1)
    let dbl = \(x: int => x * 2)
    println(f"inc(5) = {inc(5)}")
    println(f"dbl(5) = {dbl(5)}")

    // --- Multi-parameter lambda ---
    let add = \(a: int, b: int => a + b)
    println(f"add(3, 7) = {add(3, 7)}")

    // --- Passing lambdas to higher-order functions ---
    let r1 = apply(\(x: int => x * x), 6)
    println(f"apply(square, 6) = {r1}")

    let r2 = apply_twice(\(x: int => x + 10), 5)
    println(f"apply_twice(+10, 5) = {r2}")

    // --- Closures: lambdas that capture variables ---
    let factor = 7
    let times_factor = \(x: int => x * factor)
    println(f"3 * 7 = {times_factor(3)}")

    let base = 100
    let offset = 42
    let compute = \(x: int => x + base + offset)
    println(f"1 + 100 + 42 = {compute(1)}")

    // --- Returning closures from functions ---
    let add5 = make_adder(5)
    let add100 = make_adder(100)
    println(f"add5(10) = {add5(10)}")
    println(f"add100(10) = {add100(10)}")

    // --- Named functions as values ---
    let r3 = apply(triple, 4)
    println(f"apply(triple, 4) = {r3}")

    // --- Lambda in composition chain ---
    let r4 = 5 -> \(x: int => x * 2) -> \(x: int => x + 1)
    println(f"5 -> *2 -> +1 = {r4}")

    // --- Combining chains with named and anonymous functions ---
    let r5 = 10 -> triple -> \(x: int => x - 1)
    println(f"10 -> triple -> -1 = {r5}")
}
