{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python3 -m unittest:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(python3:*)",
      "Bash(git log:*)",
      "Bash(clang:*)",
      "Bash(python -c:*)",
      "Bash(source:*)",
      "Bash(python -m pytest:*)"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/absolute/path/to/your/reflow/project"
      ]
    },
    "shell": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-shell"
      ],
      "env": {
        "ALLOW_COMMANDS": "make,python,python3,clang,diff,cat,ls,mkdir,cp,mv,rm,grep,find,git"
      }
    }
  }
}
