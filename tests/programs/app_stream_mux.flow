; app_stream_mux.flow — Stream multiplexer
; Exercises: pattern matching for routing, map<string,string>,
; conditional routing, record types, composition chains
module tests.app_stream_mux

import io (println)
import string
import array
import conv
import map

; --- Types ---

type Record {
    category: string
    priority: int
    data: string
}

; --- Routing and formatting ---

fn:pure route(r: Record): string {
    if r.category == "error"  { return "alerts" }
    if r.category == "metric" { return "metrics" }
    if r.category == "audit"  { return "archive" }
    return "default"
}

fn:pure format_record(r: Record): string {
    return "[" + r.category + "/" + conv.to_string(r.priority) + "] " + r.data
}

; --- Main ---

fn main() {
    let records = [
        Record { category: "error",  priority: 1, data: "disk full" },
        Record { category: "metric", priority: 3, data: "cpu=72%" },
        Record { category: "audit",  priority: 2, data: "user login" },
        Record { category: "error",  priority: 1, data: "OOM" },
        Record { category: "metric", priority: 3, data: "mem=85%" },
        Record { category: "info",   priority: 4, data: "startup complete" }
    ]

    ; Route each record and collect formatted output per destination
    let destinations: map<string, string>:mut = map.new()
    for (r: Record in records) {
        let dest = route(r)
        let line = format_record(r)
        let existing = map.get(destinations, dest) ?? ""
        destinations = map.set(destinations, dest, existing + line + "\n")
    }

    ; Print each destination's collected output
    let ks = map.keys(destinations)
    for (key: string in ks) {
        println("=== " + key + " ===")
        println(map.get(destinations, key) ?? "")
    }
}
