module tests.app_calc

; Self-test for the calculator app.
; Exercises: recursive sum types, match, fn:pure, tuples, map, math.pow

import io
import string
import conv
import math
import map
import char

; --- AST (same as apps/calc/calc.flow) ---

type Expr =
    | Literal(value: float)
    | Var(name: string)
    | Neg(inner: Expr)
    | BinOp(op: string, left: Expr, right: Expr)

; --- Parser (same as apps/calc/calc.flow) ---

fn:pure skip_ws(input: string, pos: int): int {
    let p: int:mut = pos
    let length = string.len(input)
    while (p < length) {
        let ch = string.char_at(input, p) ?? 'x'
        if char.is_whitespace(ch) {
            p = p + 1
        } else {
            break
        }
    }
    return p
}

fn:pure peek_char(input: string, pos: int): string {
    let p = skip_ws(input, pos)
    if p >= string.len(input) {
        return ""
    }
    let ch = string.char_at(input, p) ?? ' '
    return char.to_string(ch)
}

fn parse_number(input: string, pos: int): (Expr, int) {
    let start = pos
    let p: int:mut = pos
    let length = string.len(input)
    while (p < length) {
        let ch = string.char_at(input, p) ?? ' '
        if char.is_digit(ch) {
            p = p + 1
        } else {
            break
        }
    }
    if p < length {
        let dot = string.char_at(input, p) ?? ' '
        if char.to_string(dot) == "." {
            p = p + 1
            while (p < length) {
                let ch = string.char_at(input, p) ?? ' '
                if char.is_digit(ch) {
                    p = p + 1
                } else {
                    break
                }
            }
        }
    }
    let num_str = string.substring(input, start, p)
    let value = conv.string_to_float(num_str) ?? 0.0
    return (Literal(value), p)
}

fn parse_ident(input: string, pos: int): (string, int) {
    let start = pos
    let p: int:mut = pos
    let length = string.len(input)
    while (p < length) {
        let ch = string.char_at(input, p) ?? ' '
        if char.is_alphanumeric(ch) {
            p = p + 1
        } else {
            let cs = char.to_string(ch)
            if cs == "_" {
                p = p + 1
            } else {
                break
            }
        }
    }
    return (string.substring(input, start, p), p)
}

fn parse_primary(input: string, pos: int): (Expr, int) {
    let p = skip_ws(input, pos)
    if p >= string.len(input) {
        return (Literal(0.0), p)
    }
    let ch = string.char_at(input, p) ?? ' '
    if char.is_digit(ch) {
        return parse_number(input, p)
    }
    if char.is_alpha(ch) {
        let result = parse_ident(input, p)
        return (Var(result.0), result.1)
    }
    let cs = char.to_string(ch)
    if cs == "(" {
        let inner = parse_expr(input, p + 1)
        let close_pos = skip_ws(input, inner.1)
        if close_pos < string.len(input) {
            let close_ch = string.char_at(input, close_pos) ?? ' '
            if char.to_string(close_ch) == ")" {
                return (inner.0, close_pos + 1)
            }
        }
        return (inner.0, inner.1)
    }
    return (Literal(0.0), p + 1)
}

fn parse_unary(input: string, pos: int): (Expr, int) {
    let p = skip_ws(input, pos)
    if p < string.len(input) {
        let ch = string.char_at(input, p) ?? ' '
        if char.to_string(ch) == "-" {
            let result = parse_unary(input, p + 1)
            return (Neg(result.0), result.1)
        }
    }
    return parse_primary(input, p)
}

fn parse_power(input: string, pos: int): (Expr, int) {
    let base = parse_unary(input, pos)
    let p = skip_ws(input, base.1)
    if p < string.len(input) {
        let ch = string.char_at(input, p) ?? ' '
        if char.to_string(ch) == "^" {
            let exp = parse_power(input, p + 1)
            return (BinOp("^", base.0, exp.0), exp.1)
        }
    }
    return (base.0, base.1)
}

fn parse_multiplicative(input: string, pos: int): (Expr, int) {
    let first = parse_power(input, pos)
    let left: Expr:mut = first.0
    let cur: int:mut = first.1
    let running: bool:mut = true
    while (running) {
        let p = skip_ws(input, cur)
        if p >= string.len(input) {
            running = false
        } else {
            let ch = peek_char(input, cur)
            if ch == "*" {
                let rhs = parse_power(input, p + 1)
                left = BinOp("*", left, rhs.0)
                cur = rhs.1
            } else if ch == "/" {
                let rhs = parse_power(input, p + 1)
                left = BinOp("/", left, rhs.0)
                cur = rhs.1
            } else {
                running = false
            }
        }
    }
    return (left, cur)
}

fn parse_additive(input: string, pos: int): (Expr, int) {
    let first = parse_multiplicative(input, pos)
    let left: Expr:mut = first.0
    let cur: int:mut = first.1
    let running: bool:mut = true
    while (running) {
        let p = skip_ws(input, cur)
        if p >= string.len(input) {
            running = false
        } else {
            let ch = peek_char(input, cur)
            if ch == "+" {
                let rhs = parse_multiplicative(input, p + 1)
                left = BinOp("+", left, rhs.0)
                cur = rhs.1
            } else if ch == "-" {
                let rhs = parse_multiplicative(input, p + 1)
                left = BinOp("-", left, rhs.0)
                cur = rhs.1
            } else {
                running = false
            }
        }
    }
    return (left, cur)
}

fn parse_expr(input: string, pos: int): (Expr, int) {
    return parse_additive(input, pos)
}

; --- Evaluator ---

fn eval(expr: Expr, env: map<string, string>): float {
    match expr {
        Literal(n): {
            return n
        }
        Var(name): {
            let str_val = map.get(env, name) ?? "0"
            return conv.string_to_float(str_val) ?? 0.0
        }
        Neg(inner): {
            return 0.0 - eval(inner, env)
        }
        BinOp(op, left, right): {
            let lv = eval(left, env)
            let rv = eval(right, env)
            if op == "+" {
                return lv + rv
            } else if op == "-" {
                return lv - rv
            } else if op == "*" {
                return lv * rv
            } else if op == "/" {
                if rv == 0.0 {
                    return 0.0
                }
                return lv / rv
            } else if op == "^" {
                return math.pow(lv, rv)
            } else {
                return 0.0
            }
        }
    }
}

; --- Helpers ---

fn format_result(value: float): string {
    let as_int = cast<int>(value)
    let back = cast<float>(as_int)
    if back == value {
        return conv.to_string(as_int)
    }
    return conv.to_string(value)
}

fn eval_and_print(label: string, input: string, env: map<string, string>): none {
    let parsed = parse_expr(input, 0)
    let result = eval(parsed.0, env)
    io.println(label + " = " + format_result(result))
}

; --- Test suite ---

fn main(): none {
    let env: map<string, string>:mut = map.new()

    ; Basic arithmetic
    eval_and_print("2 + 3", "2 + 3", env)
    eval_and_print("10 - 4", "10 - 4", env)
    eval_and_print("3 * 7", "3 * 7", env)
    eval_and_print("20 / 4", "20 / 4", env)

    ; Precedence
    eval_and_print("2 + 3 * 4", "2 + 3 * 4", env)
    eval_and_print("(2 + 3) * 4", "(2 + 3) * 4", env)

    ; Unary negation
    eval_and_print("-5", "-5", env)
    eval_and_print("-5 + 3", "-5 + 3", env)
    eval_and_print("-(2 + 3)", "-(2 + 3)", env)

    ; Exponentiation
    eval_and_print("2 ^ 10", "2 ^ 10", env)
    eval_and_print("3 ^ 2", "3 ^ 2", env)

    ; Nested expressions
    eval_and_print("(1 + 2) * (3 + 4)", "(1 + 2) * (3 + 4)", env)
    eval_and_print("2 ^ 2 ^ 3", "2 ^ 2 ^ 3", env)

    ; Variables
    env = map.set(env, "x", "10")
    env = map.set(env, "y", "5")
    eval_and_print("x + y", "x + y", env)
    eval_and_print("x * y", "x * y", env)
    eval_and_print("x ^ 2", "x ^ 2", env)

    ; Float arithmetic
    eval_and_print("3.14 * 2", "3.14 * 2", env)
    eval_and_print("1 / 3", "1 / 3", env)

    io.println("All tests passed")
}
