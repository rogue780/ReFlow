; congruence_test.flow — E2E test for the === congruence operator
module tests.congruence_test

import io (println)

type LogEntry {
    timestamp: int
    source: string
}

type EventRecord {
    timestamp: int
    source: string
}

type MetricPoint {
    timestamp: int
    value: float
}

fn main() {
    let a = LogEntry { timestamp: 100, source: "us-east-1" }
    let b = EventRecord { timestamp: 200, source: "eu-west-1" }
    let c = MetricPoint { timestamp: 300, value: 3.14 }

    ; Same fields → congruent
    if a === b {
        println("a === b: true")
    } else {
        println("a === b: false")
    }

    ; Different fields → not congruent
    if a === c {
        println("a === c: true")
    } else {
        println("a === c: false")
    }
}
