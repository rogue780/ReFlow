; coroutine_poll_test.reflow — Tests .poll() non-blocking method
module tests.coroutine_poll_test

import io (println)

; A simple generator that yields 3 values
fn counter(): stream<int> {
    yield 1
    yield 2
    yield 3
}

fn main() {
    ; Start a coroutine
    let gen :< counter()

    ; .poll() on a non-threaded coroutine calls rf_stream_next
    ; which returns values directly (same as .next() for non-threaded)
    match gen.poll() {
        some(v): { println(f"poll={v}") }
        none: { println("poll=none") }
    }
    match gen.poll() {
        some(v): { println(f"poll={v}") }
        none: { println("poll=none") }
    }
    match gen.poll() {
        some(v): { println(f"poll={v}") }
        none: { println("poll=none") }
    }

    ; After exhaustion, poll returns none
    match gen.poll() {
        some(v): { println(f"poll={v}") }
        none: { println("poll=none") }
    }

    println(f"done={gen.done()}")
}
