module tests.coroutine_pipeline_test
import io (println)

; Stage 1: generates integers
fn producer(): stream<int> {
    let i: int:mut = 1
    while (i <= 4) {
        yield i
        i = i + 1
    }
}

; Stage 2: doubles each value (receivable)
fn doubler(inbox: stream<int>): stream<int> {
    for (val: int in inbox) {
        yield val * 2
    }
}

; Stage 3: adds 100 to each value (receivable)
fn adder(inbox: stream<int>): stream<int> {
    for (val: int in inbox) {
        yield val + 100
    }
}

fn main() {
    ; Pipeline syntax: producer -> doubler -> adder
    let result :< producer() -> doubler() -> adder()

    ; Should produce: 1*2+100=102, 2*2+100=104, 3*2+100=106, 4*2+100=108
    while (!result.done()) {
        match result.next() {
            some(v): { println(f"{v}") }
            none: {}
        }
    }
    println("done")
}
