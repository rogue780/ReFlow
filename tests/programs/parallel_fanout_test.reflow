module tests.parallel_fanout_test
import io (println)

fn:pure double(x: int): int = x * 2
fn:pure square(x: int): int = x * x
fn:pure add(a: int, b: int): int = a + b

fn:pure greet(s: string): string = f"Hello, {s}!"
fn:pure shout(s: string): string = f"{s}!!!"
fn:pure both(a: string, b: string): string = f"{a} and {b}"

fn main() {
    let r1 = 5 -> <:(double | square) -> add
    println(f"parallel: {r1}")

    let r2 = "hello" -> <:(greet | shout) -> both
    println(r2)
}
