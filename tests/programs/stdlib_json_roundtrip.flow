module stdlib_json_roundtrip

import json
import conv
import io

fn main(): void {
    let parsed = json.parse("{\"name\":\"Flow\",\"version\":42}")
    match parsed {
        some(val): {
            io.println(json.to_string(val))
            let name = json.get(val, "name")
            match name {
                some(n): {
                    match json.as_string(n) {
                        some(s): io.println(s)
                        none: io.println("not a string")
                    }
                }
                none: io.println("no name")
            }
            let ver = json.get(val, "version")
            match ver {
                some(v): {
                    match json.as_int(v) {
                        some(n): io.println(conv.to_string(n))
                        none: io.println("not an int")
                    }
                }
                none: io.println("no version")
            }
        }
        none: io.println("parse failed")
    }
    // Builder test: construct and serialize
    let built = json.bool_val(true)
    io.println(json.to_string(built))
    io.println(conv.to_string(json.is_null(json.null_val())))
}
