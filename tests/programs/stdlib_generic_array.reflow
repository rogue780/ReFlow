; stdlib_generic_array.reflow — Tests generic array functions
module tests.stdlib_generic_array

import io (println)
import array
import conv

fn main() {
    ; Test push<T> with strings (pointer type)
    let strs: array<string>:mut = []
    strs = array.push(strs, "hello")
    strs = array.push(strs, "world")
    println(f"size={array.size(strs)}")

    match array.get_any(strs, 0) {
        some(v): { println(f"strs[0]={v}") }
        none: { println("strs[0]=none") }
    }
    match array.get_any(strs, 1) {
        some(v): { println(f"strs[1]={v}") }
        none: { println("strs[1]=none") }
    }

    ; Test push_int (value type)
    let nums: array<int>:mut = []
    nums = array.push_int(nums, 10)
    nums = array.push_int(nums, 20)
    nums = array.push_int(nums, 30)
    println(f"nums size={array.size(nums)}")

    match array.get_int(nums, 0) {
        some(v): { println(f"nums[0]={v}") }
        none: { println("nums[0]=none") }
    }
    match array.get_int(nums, 2) {
        some(v): { println(f"nums[2]={v}") }
        none: { println("nums[2]=none") }
    }

    ; Test push_float
    let floats: array<float>:mut = []
    floats = array.push_float(floats, 1.5)
    floats = array.push_float(floats, 2.5)
    println(f"floats size={array.size(floats)}")

    match array.get_float(floats, 0) {
        some(v): { println(f"floats[0]={v}") }
        none: { println("floats[0]=none") }
    }

    ; Test concat<T> with strings
    let a: array<string>:mut = []
    a = array.push(a, "a")
    let b: array<string>:mut = []
    b = array.push(b, "b")
    let ab = array.concat(a, b)
    println(f"concat size={array.size(ab)}")

    match array.get_any(ab, 0) {
        some(v): { println(f"ab[0]={v}") }
        none: { println("ab[0]=none") }
    }
    match array.get_any(ab, 1) {
        some(v): { println(f"ab[1]={v}") }
        none: { println("ab[1]=none") }
    }

    ; Test push_bool
    let bools: array<bool>:mut = []
    bools = array.push_bool(bools, true)
    bools = array.push_bool(bools, false)
    println(f"bools size={array.size(bools)}")

    match array.get_bool(bools, 0) {
        some(v): { println(f"bools[0]={v}") }
        none: { println("bools[0]=none") }
    }
    match array.get_bool(bools, 1) {
        some(v): { println(f"bools[1]={v}") }
        none: { println("bools[1]=none") }
    }
}
