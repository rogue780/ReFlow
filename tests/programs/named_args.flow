// Test named arguments
import io (println)

fn greet(name:string, greeting:string = "Hello"):string {
    return greeting + ", " + name + "!"
}

fn add(a:int, b:int, c:int):int {
    return a + b + c
}

fn main():none {
    // Named args reordered
    println(f"{add(c: 3, b: 2, a: 1)}")
    // Named with default
    println(greet(name: "World"))
    // Named overriding default
    println(greet(name: "World", greeting: "Hi"))
    // Positional + named
    println(greet("World", greeting: "Hey"))
}
