// Test default parameter values
import io (println)

fn greet(name:string, greeting:string = "Hello"):string {
    return greeting + ", " + name + "!"
}

fn add(a:int, b:int = 10, c:int = 20):int {
    return a + b + c
}

fn main():none {
    // Call with default omitted
    println(greet("World"))
    // Call with all args
    println(greet("World", "Hi"))
    // Call with two defaults omitted
    println(f"{add(1)}")
    // Call with one default omitted
    println(f"{add(1, 2)}")
    // Call with no defaults omitted
    println(f"{add(1, 2, 3)}")
}
