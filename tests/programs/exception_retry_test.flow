module tests.exception_retry_test

import io (println)

fn parse_value(s: string): int {
    if s == "bad" {
        throw "parse error"
    }
    return 42
}

fn main() {
    ; Test retry: function throws, retry body runs, then retries
    ; Since retry re-executes the try body, and we can't modify the
    ; string exception in a meaningful way for retry, this tests the
    ; retry-then-catch escalation pattern.
    try {
        let val = parse_value("bad")
        println(f"got: {val}")
    } retry parse_value (ex: string, attempts: 2) {
        println(f"retry attempt")
    } catch (ex: string) {
        println("retries exhausted, caught")
    } finally {
        println("finally after retry")
    }

    println("done")
}
